<%- include('../layout/header.ejs') -%>
</head>

<body>
    <div class="page-wrapper">
        <%- include('../partials/navbar.ejs') -%>
        
        <main class="main">
            <div class="page-header text-center" style="background-image: url('/static/images/page-header-bg.jpg')">
                <div class="container">
                    <h1 class="page-title">My Wishlist<span>Your curated style shortlist.</span></h1>
                </div>
            </div>

            <nav aria-label="breadcrumb" class="breadcrumb-nav mb-4">
                <div class="container">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a href="/">Home</a></li>
                        <li class="breadcrumb-item"><a href="/shop">Shop</a></li>
                        <li class="breadcrumb-item active" aria-current="page">Wishlist</li>
                    </ol>
                </div>
            </nav>

            <div class="page-content">
                <div class="container">
                    <% if (products.length > 0) { %>
                        <div class="cart-table-container">
                            <table class="table table-cart m-0">
                                <thead>
                                    <tr>
                                        <th>Product Details</th>
                                        <th class="text-center">Price</th>
                                        <th class="text-center">Stock Status</th>
                                        <th class="text-center">Action</th>
                                        <th class="text-center">Remove</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% products.forEach(product => { %>
                                        <tr>
                                            <td>
                                                <div class="product-col" style="display:flex; align-items:center; gap:16px;">
                                                    <div class="product-media" style="width:70px; height:70px; border-radius:8px; overflow:hidden; border:1px solid #e2e2ec; flex-shrink:0;">
                                                        <img src="<%= product.images[0] %>" alt="<%= product.title %>" style="width:100%; height:100%; object-fit:cover;">
                                                    </div>
                                                    <h3 class="product-title" style="font-size:14px; font-weight:600; margin:0;"><%= product.title %></h3>
                                                </div>
                                            </td>
                                            <td class="text-center" style="font-weight:600; color:#1a1a2e;">₹<%= product.disPrice %></td>
                                            <td class="text-center">
                                                <% if (product.stock > 0) { %>
                                                    <span class="status-badge status-active">In stock</span>
                                                <% } else { %>
                                                    <span class="status-badge status-blocked">Out of stock</span>
                                                <% } %>
                                            </td>
                                            <td class="text-center">
                                                <% if (product.stock > 0) { %>
                                                    <form action="/cart/add/<%= product._id %>" method="POST" class="m-0">
                                                        <button type="submit" class="btn-fz-primary" style="padding:8px 20px !important; font-size:12px !important; cursor:pointer;">
                                                            Add to bag
                                                        </button>
                                                    </form>
                                                <% } else { %>
                                                    <button class="clear-link disabled" style="padding:8px 20px !important; font-size:12px !important; opacity:0.5; cursor:not-allowed;">Out of Stock</button>
                                                <% } %>
                                            </td>
                                            <td class="text-center">
                                                <form method="POST" action="/removewishlist" class="m-0">
                                                    <input type="hidden" name="productId" value="<%= product._id %>">
                                                    <button type="submit" class="btn-remove" style="border:none; cursor:pointer; background:none; margin:0 auto;"><i class="icon-close"></i></button>
                                                </form>
                                            </td>
                                        </tr>
                                    <% }); %>
                                </tbody>
                            </table>
                        </div>
                    <% } else { %>
                        <div class="text-center py-5">
                            <i class="icon-heart-o mb-3" style="font-size:3rem; color:#c9a96e; display:block;"></i>
                            <h3 style="font-family:'Playfair Display', serif; font-weight:600; color:#1a1a2e; margin-bottom:8px;">Your Wishlist is Empty</h3>
                            <p style="color:#777; font-size:14px; margin-bottom:20px;">Save your favorite pieces here to purchase them later.</p>
                            <a href="/shop" class="btn-fz-primary" style="display:inline-block; padding:12px 28px !important;">Explore Shop</a>
                        </div>
                    <% } %>

                    <div class="wishlist-share mt-5 text-center">
                        <div class="social-icons social-icons-sm justify-content-center">
                            <label class="social-label">Share shortlist:</label>
                            <a href="#" class="social-icon" title="Facebook" target="_blank"><i class="icon-facebook-f"></i></a>
                            <a href="#" class="social-icon" title="Twitter" target="_blank"><i class="icon-twitter"></i></a>
                            <a href="#" class="social-icon" title="Instagram" target="_blank"><i class="icon-instagram"></i></a>
                            <a href="#" class="social-icon" title="Pinterest" target="_blank"><i class="icon-pinterest"></i></a>
                        </div>
                    </div>
                </div>
            </div>
        </main>

        <%- include('../partials/footer.ejs')-%>
    </div>
</body>
</html>