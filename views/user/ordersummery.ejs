<%- include('../layout/header.ejs') -%>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.js"></script>
</head>

<body>
    <div class="page-wrapper">
        <%- include('../partials/navbar.ejs') -%>

        <main class="main">
            <div class="page-header text-center" style="background-image: url('/assets/images/page-header-bg.jpg')">
                <div class="container">
                    <h1 class="page-title">Order Invoice Summary<span>Thank you for shopping with us!</span></h1>
                </div>
            </div>

            <nav aria-label="breadcrumb" class="breadcrumb-nav mb-4">
                <div class="container">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a href="/">Home</a></li>
                        <li class="breadcrumb-item active" aria-current="page">Invoice Details</li>
                    </ol>
                </div>
            </nav>

            <div class="container order-summary-container p-5" style="max-width:850px; background:#fff; border-radius:24px; border:1px solid #e2e2ec; box-shadow:0 12px 40px rgba(0,0,0,0.04); margin-bottom:50px;">
                <div class="text-center mb-5">
                    <div style="width:72px; height:72px; border-radius:50%; background:rgba(39,174,96,0.1); color:#27ae60; font-size:2rem; display:inline-flex; align-items:center; justify-content:center; margin-bottom:18px;">
                        <i class="icon-check"></i>
                    </div>
                    <h2 class="font-heading" style="font-size:2.2rem; font-weight:700; color:#1a1a2e; margin:0 0 6px 0;">Order Placed Successfully</h2>
                    <p style="color:#777; font-size:14px; margin:0;">Your purchase receipt and shipping invoice are detailed below.</p>
                </div>

                <div class="row mb-5" style="border-top:1.5px solid #e2e2ec; border-bottom:1.5px solid #e2e2ec; padding:30px 0;">
                    <!-- Order Info Column -->
                    <div class="col-md-6 mb-4 mb-md-0">
                        <h4 class="font-heading mb-3" style="font-size:1.2rem; font-weight:700; color:#1a1a2e;">Invoice Information</h4>
                        <p style="font-size:13.5px; line-height:1.7; color:#555; margin:0;">
                            <strong>Order ID:</strong> <span style="color:#1a1a2e; font-weight:600;"><%= order.orderId %></span><br>
                            <strong>Purchase Date:</strong> <%= new Date(order.createdAt).toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" }) %><br>
                            <strong>Payment Method:</strong> <%= order.paymentMethod %><br>
                            <strong>Payment Status:</strong> 
                            <span class="status-badge <%= order.paymentStatus === 'Paid' ? 'status-active' : order.paymentStatus === 'Failed' ? 'status-blocked' : 'status-pending' %>" style="text-transform:uppercase; margin-left:6px;"><%= order.paymentStatus %></span><br>
                            <strong>Order Status:</strong> 
                            <span class="status-badge <%= order.status === 'Delivered' ? 'status-active' : order.status === 'Pending' ? 'status-pending' : 'status-blocked' %>" style="text-transform:uppercase; margin-left:6px;"><%= order.status %></span>
                        </p>

                        <% if (order.paymentStatus !== "Paid") { %>
                            <div class="mt-4">
                                <form id="payment-form" class="m-0">
                                    <input type="hidden" name="totalAmount" value="<%= order.totalAmount %>">
                                    <input type="hidden" name="orderId" value="<%= order.orderId %>">
                                    <button type="button" id="payNow" class="btn-fz-primary" style="padding:10px 28px !important; font-size:12.5px !important; cursor:pointer;">Pay Outstanding Balance</button>
                                </form>
                            </div>
                        <% } %>
                    </div>

                    <!-- Shipping Address Column -->
                    <div class="col-md-6">
                        <h4 class="font-heading mb-3" style="font-size:1.2rem; font-weight:700; color:#1a1a2e;">Delivery Destination</h4>
                        <p style="font-size:13.5px; line-height:1.7; color:#555; margin:0;">
                            <strong style="color:#1a1a2e;"><%= shippedAddress.name %></strong><br>
                            <%= shippedAddress.phone %><br>
                            <%= shippedAddress.house %>, <%= shippedAddress.city %><br>
                            <%= shippedAddress.state %>, <%= shippedAddress.country %> — <%= shippedAddress.pincode %>
                        </p>
                    </div>
                </div>

                <h3 class="font-heading mb-3" style="font-size:1.2rem; font-weight:700; color:#1a1a2e;">Ordered Shortlist</h3>
                <div class="cart-table-container mb-4">
                    <table class="table table-cart m-0">
                        <thead>
                            <tr>
                                <th>Product Details</th>
                                <th class="text-center">Quantity</th>
                                <th class="text-center">Unit Price</th>
                                <th class="text-center">Subtotal</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (order.products && order.products.length > 0) { %>
                                <% order.products.forEach(product => { %>
                                    <% if (product.items && product.items.length > 0) { %>
                                        <% product.items.forEach(item => { %>
                                            <tr style="<%= item.display ? '' : 'opacity: 0.5;' %>">
                                                <td>
                                                    <div class="d-flex align-items-center gap-3">
                                                        <div style="width:50px; height:50px; border-radius:6px; overflow:hidden; border:1px solid #e2e2ec; flex-shrink:0;">
                                                            <img src="/<%= item.image %>" alt="<%= item.title %>" style="width:100%; height:100%; object-fit:cover;">
                                                        </div>
                                                        <span style="font-weight:600; font-size:13.5px; color:#1a1a2e;"><%= item.title %></span>
                                                    </div>
                                                </td>
                                                <td class="text-center" style="font-weight:600;"><%= item.quantity %></td>
                                                <td class="text-center" style="font-weight:500;">₹<%= item.price %></td>
                                                <td class="text-center" style="font-weight:600; color:#1a1a2e;">₹<%= (item.quantity * item.price) %></td>
                                            </tr>
                                        <% }); %>
                                    <% } %>
                                <% }); %>
                            <% } %>
                        </tbody>
                    </table>
                </div>

                <div class="d-flex justify-content-end mb-5">
                    <div style="background:#fafafa; border-radius:16px; border:1px solid #e2e2ec; padding:24px; min-width:300px;">
                        <div class="d-flex justify-content-between py-2 border-bottom" style="border-color:#f1f1f5 !important; font-size:13.5px;">
                            <span style="color:#777;">Promo Price Discounts:</span>
                            <span style="font-weight:600; color:#eb5e55;">₹<%= order.totalAmount %></span>
                        </div>
                        <div class="d-flex justify-content-between pt-3" style="font-size:15px;">
                            <strong style="color:#1a1a2e;">Grand Total Paid:</strong>
                            <strong style="color:#27ae60; font-size:1.2rem;">₹<%= order.totalAmount %></strong>
                        </div>
                    </div>
                </div>

                <div class="text-center buttons-wrapper mt-4 d-flex justify-content-center gap-3 flex-wrap">
                    <a href="/shop" class="clear-link" style="display:inline-block; padding:12px 28px !important; border-radius:50px !important; border:1.5px solid #e2e2ec !important; background:#fff !important; color:#555 !important; font-size:13px; font-weight:600; text-decoration:none; text-transform:uppercase; letter-spacing:0.5px; margin:0;">Continue Shopping</a>
                    <a href="/profile" class="clear-link" style="display:inline-block; padding:12px 28px !important; border-radius:50px !important; border:1.5px solid #e2e2ec !important; background:#fff !important; color:#555 !important; font-size:13px; font-weight:600; text-decoration:none; text-transform:uppercase; letter-spacing:0.5px; margin:0;">View Order List</a>
                    <button id="downloadInvoice" class="btn-fz-primary" style="padding:12px 28px !important; font-size:13px !important; font-weight:600; text-transform:uppercase; letter-spacing:0.5px; cursor:pointer;">Download Invoice PDF</button>
                </div>
            </div>
        </main>

        <%- include('../partials/footer.ejs')-%>
    </div>

    <!-- Razorpay payment continuation script -->
    <script src="https://checkout.razorpay.com/v1/checkout.js"></script>
    <script>
        const payNowButton = document.getElementById("payNow");
        if (payNowButton) {
            payNowButton.addEventListener("click", function() {
                const totalAmount = document.querySelector('input[name="totalAmount"]').value;
                const orderId = document.querySelector('input[name="orderId"]').value;

                Swal.fire({
                    title: 'Confirm Payment',
                    text: "You are about to securely initiate payment verification.",
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonText: 'Pay Now',
                    cancelButtonText: 'Cancel'
                }).then((result) => {
                    if (result.isConfirmed) {
                        fetch('/ordersummany/continerazorpaypayment', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ totalAmount, orderId })
                        })
                        .then(response => response.json())
                        .then(data => {
                            if (data.success) {
                                var options = {
                                    key: "rzp_test_SsN3kF1vkA34wm",
                                    amount: data.amount,
                                    currency: data.currency,
                                    name: "FashionZone",
                                    description: "Continuation Payment",
                                    order_id: data.orderId,
                                    handler: function(response) {
                                        const { razorpay_order_id, razorpay_payment_id, razorpay_signature } = response;
                                        fetch('/verifyorderpayment', {
                                            method: 'POST',
                                            headers: { 'Content-Type': 'application/json' },
                                            body: JSON.stringify({
                                                razorpay_order_id,
                                                razorpay_payment_id,
                                                razorpay_signature,
                                                orderId
                                            })
                                        })
                                        .then(response => response.json())
                                        .then(data => {
                                            if (data.success) {
                                                Swal.fire({
                                                    title: 'Success!',
                                                    text: 'Your payment was successful!',
                                                    icon: 'success'
                                                }).then(() => {
                                                    window.location.reload();
                                                });
                                            } else {
                                                Swal.fire({
                                                    title: 'Error!',
                                                    text: 'Payment verification failed.',
                                                    icon: 'error'
                                                });
                                            }
                                        });
                                    },
                                    prefill: {
                                        name: "Customer",
                                        email: "customer@example.com",
                                        contact: "1234567890"
                                    },
                                    theme: {
                                        color: "#1a1a2e"
                                    }
                                };
                                var rzp1 = new Razorpay(options);
                                rzp1.open();
                            } else {
                                Swal.fire({
                                    title: 'Error!',
                                    text: 'Failed to create Razorpay order.',
                                    icon: 'error'
                                });
                            }
                        });
                    }
                });
            });
        }
    </script>

    <!-- PDF Invoice Generation Script -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.4.0/jspdf.umd.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
    <script>
        document.getElementById('downloadInvoice').addEventListener('click', function () {
            const orderSummary = document.querySelector('.order-summary-container');
            const buttonsDiv = document.querySelector('.buttons-wrapper');

            if (buttonsDiv) buttonsDiv.style.display = 'none';

            html2canvas(orderSummary, {
                scale: 2,
                useCORS: true,
            }).then(canvas => {
                const imgData = canvas.toDataURL('image/png');
                const { jsPDF } = window.jspdf;
                const pdf = new jsPDF('p', 'mm', 'a4');

                pdf.setFontSize(22);
                pdf.setFont('playfair', 'bold');
                pdf.setTextColor(201, 169, 110);
                pdf.text('FashionZone', pdf.internal.pageSize.getWidth() / 2, 15, { align: 'center' });

                const pdfWidth = pdf.internal.pageSize.getWidth();
                const pdfHeight = (canvas.height * pdfWidth) / canvas.width;

                pdf.addImage(imgData, 'PNG', 0, 22, pdfWidth, pdfHeight);
                pdf.save('FashionZone-Invoice.pdf');

                if (buttonsDiv) buttonsDiv.style.display = 'flex';
            }).catch(error => {
                console.error('Error generating PDF:', error);
                if (buttonsDiv) buttonsDiv.style.display = 'flex';
            });
        });
    </script>
</body>
</html>