<%- include('../layout/header.ejs') -%>
</head>

<div class="auth-wrapper" style="min-height: 100vh; display: flex; align-items: center; justify-content: center; background: linear-gradient(135deg, var(--fz-dark) 0%, var(--fz-dark-2) 50%, #0f1222 100%) !important; padding: 40px 20px;">
    <div class="auth-card" style="background: rgba(255,255,255,0.06) !important; backdrop-filter: blur(20px) !important; -webkit-backdrop-filter: blur(20px) !important; border: 1px solid rgba(255,255,255,0.1) !important; border-radius: 20px; padding: 48px 40px; width: 100%; max-width: 440px; box-shadow: 0 32px 80px rgba(0,0,0,0.5) !important;">
        
        <div class="auth-logo" style="font-family: var(--font-heading) !important; font-size: 2.2rem !important; font-weight: 700 !important; background: linear-gradient(135deg, var(--fz-gold-light), var(--fz-gold-dark)) !important; -webkit-background-clip: text !important; -webkit-text-fill-color: transparent !important; background-clip: text !important; text-align: center; margin-bottom: 6px; letter-spacing: 1px;">FashionZone</div>
        <div class="auth-subtitle" style="text-align: center; color: rgba(255,255,255,0.5) !important; font-size: 13.5px; margin-bottom: 32px; letter-spacing: 0.5px; text-transform: uppercase; font-weight: 600;">Admin Portal</div>

        <% if (messages && messages.message && messages.message.length > 0) { %>
            <div class="alert alert-danger" style="background: rgba(231,76,60,0.15); border: 1px solid rgba(231,76,60,0.25); color: #ff6b6b; font-size: 13px; border-radius: var(--fz-radius); margin-bottom: 20px; text-align: center; padding: 10px;">
                <%= messages.message[0] %>
            </div>
        <% } %>

        <form action="/admin/adminlogin" method="post">
            <div class="form-group" style="margin-bottom: 20px;">
                <label for="register-email-2" style="color: rgba(255,255,255,0.7) !important; font-weight: 500; font-size: 13px; margin-bottom: 8px; display: block;">Email Address</label>
                <input type="email" class="form-control" id="register-email-2" name="email" placeholder="admin@fashionzone.com" required style="background: rgba(255,255,255,0.05) !important; border: 1.5px solid rgba(255,255,255,0.1) !important; color: #fff !important; padding: 12px 16px !important; border-radius: var(--fz-radius) !important; font-size: 14px !important;">
                <% if (messages && messages.email && messages.email.length > 0) { %>
                    <p class="text-danger" style="font-size: 12px; margin-top: 4px; color: #ff6b6b;"><%= messages.email[0] %></p>
                <% } %>
            </div>

            <div class="form-group" style="margin-bottom: 32px;">
                <label for="register-password-2" style="color: rgba(255,255,255,0.7) !important; font-weight: 500; font-size: 13px; margin-bottom: 8px; display: block;">Password</label>
                <div class="input-group" style="position: relative; display: flex; align-items: stretch; width: 100%;">
                    <input type="password" class="form-control" id="register-password-2" name="password" placeholder="••••••••" minlength="6" required style="background: rgba(255,255,255,0.05) !important; border: 1.5px solid rgba(255,255,255,0.1) !important; color: #fff !important; padding: 12px 16px !important; border-radius: var(--fz-radius) 0 0 var(--fz-radius) !important; font-size: 14px !important; flex: 1;">
                    <div class="input-group-append" style="display: flex;">
                        <button type="button" class="btn toggle-password" tabindex="-1" style="background: rgba(255,255,255,0.05) !important; border: 1.5px solid rgba(255,255,255,0.1) !important; border-left: none !important; color: rgba(255,255,255,0.6) !important; border-radius: 0 var(--fz-radius) var(--fz-radius) 0 !important; padding: 0 16px; cursor: pointer; transition: all 0.2s;">
                            <i class="fas fa-eye"></i>
                        </button>
                    </div>
                </div>
                <% if (messages && messages.password && messages.password.length > 0) { %>
                    <p class="text-danger" style="font-size: 12px; margin-top: 4px; color: #ff6b6b;"><%= messages.password[0] %></p>
                <% } %>
            </div>

            <button type="submit" class="btn" style="width: 100% !important; padding: 14px !important; border-radius: 50px !important; background: linear-gradient(135deg, var(--fz-gold), var(--fz-gold-dark)) !important; border: none !important; color: var(--fz-dark) !important; font-weight: 700 !important; letter-spacing: 1px !important; text-transform: uppercase !important; font-size: 13.5px !important; transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); box-shadow: 0 8px 24px rgba(201,169,110,0.25) !important;">
                Log In <i class="fas fa-arrow-right ms-2" style="font-size: 11px;"></i>
            </button>
        </form>
    </div>
</div>

<script>
    document.querySelector('.toggle-password').addEventListener('click', function () {
        const passwordInput = document.getElementById('register-password-2');
        const passwordIcon = this.querySelector('i');
        
        if (passwordInput.type === 'password') {
            passwordInput.type = 'text';
            passwordIcon.classList.remove('fa-eye');
            passwordIcon.classList.add('fa-eye-slash');
        } else {
            passwordInput.type = 'password';
            passwordIcon.classList.remove('fa-eye-slash');
            passwordIcon.classList.add('fa-eye');
        }
    });
</script>