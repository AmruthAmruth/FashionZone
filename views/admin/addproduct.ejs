<%- include('../layout/adminheader.ejs') -%>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/cropperjs@1.6.2/dist/cropper.min.css">
</head>
<body>
<div class="layout-wrapper layout-content-navbar">
  <div class="layout-container">
    <%- include('../partials/adminsidebar.ejs') -%>
    <div class="layout-page">
      <%- include('../partials/adminnavbar.ejs') -%>
      <div class="content-wrapper">
        <div class="container-xxl flex-grow-1 container-p-y">

          <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
            <div>
              <h4 class="mb-1">Add New Product</h4>
              <p class="text-muted mb-0">Fill in the details and upload four images (crop each before publishing).</p>
            </div>
            <a href="/admin/products" class="btn btn-outline-secondary btn-sm">
              <i class="ri-arrow-left-line me-1"></i> Back to products
            </a>
          </div>

          <% if (flash && flash.success) { %>
            <div class="alert alert-success alert-dismissible fade show" role="alert">
              <%= flash.success %>
              <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
          <% } %>
          <% if (flash && flash.message) { %>
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
              <%= flash.message %>
              <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
          <% } %>
          <% if (flash && flash.image) { %>
            <div class="alert alert-warning alert-dismissible fade show" role="alert">
              <%= flash.image %>
              <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
          <% } %>
          <% if (flash && (flash.price || flash.disPrice || flash.tags)) { %>
            <div class="alert alert-warning alert-dismissible fade show" role="alert">
              <%= flash.price || flash.disPrice || flash.tags %>
              <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
          <% } %>

          <form id="addProductForm" action="/admin/addproduct" method="post" enctype="multipart/form-data" novalidate onsubmit="validateAddProductForm(event)">
            <div class="row g-4">

              <div class="col-12 col-lg-8">
                <div class="card mb-4">
                  <div class="card-header">
                    <h5 class="card-title mb-0">Product information</h5>
                  </div>
                  <div class="card-body">
                    <div class="form-floating form-floating-outline mb-4">
                      <input type="text" class="form-control" id="product-brand" name="brand" placeholder="Brand" maxlength="80" required>
                      <label for="product-brand">Brand</label>
                      <div id="error-brand" class="form-error text-danger small mt-1" style="display:none;"></div>
                    </div>
                    <div class="form-floating form-floating-outline mb-4">
                      <input type="text" class="form-control" id="product-title" name="title" placeholder="Title" maxlength="120" required>
                      <label for="product-title">Title</label>
                      <div id="error-title" class="form-error text-danger small mt-1" style="display:none;"></div>
                    </div>
                    <div class="form-floating form-floating-outline mb-0">
                      <textarea class="form-control" id="product-description" name="description" placeholder="Description" style="height: 100px;" maxlength="500" required></textarea>
                      <label for="product-description">Description</label>
                      <div id="error-description" class="form-error text-danger small mt-1" style="display:none;"></div>
                    </div>
                  </div>
                </div>

                <div class="card mb-4">
                  <div class="card-header d-flex flex-wrap justify-content-between align-items-center gap-2">
                    <h5 class="card-title mb-0">Product images</h5>
                    <span class="text-muted small">JPG or PNG · 1:1 crop · 4 required</span>
                  </div>
                  <div class="card-body">
                    <p id="imagesErr" class="form-error text-danger small mb-3" style="display:none;"></p>
                    <div class="row g-3">
                      <% for (let i = 1; i <= 4; i++) { %>
                        <div class="col-sm-6">
                          <div class="border rounded p-3 text-center h-100">
                            <label for="imageInput<%= i %>" class="btn btn-outline-primary btn-sm mb-2">
                              <i class="ri-image-add-line me-1"></i> Image <%= i %>
                            </label>
                            <input
                              name="images[]"
                              type="file"
                              accept="image/jpeg,image/png"
                              id="imageInput<%= i %>"
                              class="product-image-input d-none"
                              onchange="showPreview(this, 'imagePreview<%= i %>'); openCropModal(this, <%= i %>)"
                            >
                            <div class="mt-2">
                              <img id="imagePreview<%= i %>" class="img-fluid rounded" alt="Preview <%= i %>" style="display:none; max-height: 140px; object-fit: cover;">
                            </div>
                            <p id="imageError<%= i %>" class="image-slot-error text-danger small mt-2 mb-0" style="display:none;"></p>
                          </div>
                        </div>
                      <% } %>
                    </div>
                  </div>
                </div>

                <div class="text-center mb-4">
                  <button type="submit" class="btn btn-primary px-5">
                    <i class="ri-check-line me-1"></i> Publish product
                  </button>
                </div>
              </div>

              <div class="col-12 col-lg-4">
                <div class="card mb-4">
                  <div class="card-header">
                    <h5 class="card-title mb-0">Pricing</h5>
                  </div>
                  <div class="card-body">
                    <div class="form-floating form-floating-outline mb-4">
                      <input type="number" class="form-control" id="product-price" name="price" min="0" step="0.01" placeholder="Price" required>
                      <label for="product-price">Best price (₹)</label>
                      <div id="error-price" class="form-error text-danger small mt-1" style="display:none;"></div>
                    </div>
                    <div class="form-floating form-floating-outline mb-0">
                      <input type="number" class="form-control" id="product-discount-price" name="disPrice" min="0" step="0.01" placeholder="Discounted price">
                      <label for="product-discount-price">Discounted price (optional)</label>
                      <div id="error-discount-price" class="form-error text-danger small mt-1" style="display:none;"></div>
                    </div>
                  </div>
                </div>

                <div class="card mb-4">
                  <div class="card-header">
                    <h5 class="card-title mb-0">Details</h5>
                  </div>
                  <div class="card-body">
                    <div class="mb-3">
                      <label for="color" class="form-label">Color</label>
                      <select id="color" name="color" class="form-select" required>
                        <option value="">Select color</option>
                        <option value="Black">Black</option>
                        <option value="White">White</option>
                        <option value="Gray">Gray</option>
                        <option value="Red">Red</option>
                        <option value="Yellow">Yellow</option>
                        <option value="Blue">Blue</option>
                        <option value="Green">Green</option>
                      </select>
                      <div id="error-color" class="form-error text-danger small mt-1" style="display:none;"></div>
                    </div>
                    <div class="mb-3">
                      <label for="size" class="form-label">Size</label>
                      <select id="size" name="size" class="form-select" required>
                        <option value="">Select size</option>
                        <option value="S">S</option>
                        <option value="M">M</option>
                        <option value="L">L</option>
                        <option value="XL">XL</option>
                        <option value="XXL">XXL</option>
                      </select>
                      <div id="error-size" class="form-error text-danger small mt-1" style="display:none;"></div>
                    </div>
                    <div class="mb-3">
                      <label for="category" class="form-label">Category</label>
                      <select id="category" name="category" class="form-select" required>
                        <option value="">Select category</option>
                        <% if (categories && categories.length) { %>
                          <% categories.forEach(function(cat) { %>
                            <option value="<%= cat %>"><%= cat %></option>
                          <% }); %>
                        <% } %>
                      </select>
                      <div id="error-category" class="form-error text-danger small mt-1" style="display:none;"></div>
                      <% if (!categories || !categories.length) { %>
                        <p class="text-warning small mt-1 mb-0">No categories found. <a href="/admin/categories">Add a category</a> first.</p>
                      <% } %>
                    </div>
                    <div class="mb-3">
                      <label for="gender" class="form-label">Gender</label>
                      <select id="gender" name="gender" class="form-select" required>
                        <option value="">Select gender</option>
                        <option value="men">Men</option>
                        <option value="women">Women</option>
                      </select>
                      <div id="error-gender" class="form-error text-danger small mt-1" style="display:none;"></div>
                    </div>
                    <div class="mb-3">
                      <label for="status" class="form-label">Status</label>
                      <select id="status" name="status" class="form-select" required>
                        <option value="">Select status</option>
                        <option value="Published" selected>Published</option>
                        <option value="Scheduled">Scheduled</option>
                        <option value="Inactive">Inactive</option>
                      </select>
                      <div id="error-status" class="form-error text-danger small mt-1" style="display:none;"></div>
                    </div>
                    <div class="mb-3">
                      <label for="stock" class="form-label">Stock</label>
                      <select id="stock" name="stock" class="form-select" required>
                        <option value="">Select stock</option>
                        <% for (let s = 1; s <= 10; s++) { %>
                          <option value="<%= s %>"><%= s %></option>
                        <% } %>
                      </select>
                      <div id="error-stock" class="form-error text-danger small mt-1" style="display:none;"></div>
                    </div>
                    <div class="mb-0">
                      <label for="product-tags" class="form-label">Tags</label>
                      <input type="text" class="form-control" id="product-tags" name="tags" placeholder="e.g. summer, casual, cotton" required>
                      <div class="form-text">Separate multiple tags with commas.</div>
                      <div id="error-tags" class="form-error text-danger small mt-1" style="display:none;"></div>
                    </div>
                  </div>
                </div>
              </div>

            </div>
          </form>

        </div>

        <footer class="content-footer footer bg-footer-theme">
          <div class="container-xxl">
            <div class="footer-container d-flex align-items-center justify-content-between py-3 flex-md-row flex-column">
              <span class="text-body mb-0">© FashionZone Admin</span>
            </div>
          </div>
        </footer>
        <div class="content-backdrop fade"></div>
      </div>
    </div>
  </div>
  <div class="layout-overlay layout-menu-toggle"></div>
  <div class="drag-target"></div>
</div>

<!-- Crop modal -->
<div class="modal fade" id="cropperModal" tabindex="-1" aria-labelledby="cropperModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-lg modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="cropperModalLabel">Crop image</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body p-2">
        <div style="max-height: 70vh; min-height: 280px; width: 100%;">
          <img id="imageForCrop" alt="Image to crop" style="max-width: 100%; display: block;">
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-primary" id="applyCropBtn">Apply crop</button>
      </div>
    </div>
  </div>
</div>

<script src="/assets/vendor/libs/jquery/jquery.js"></script>
<script src="/assets/vendor/js/bootstrap.js"></script>
<script src="/assets/vendor/js/menu.js"></script>
<script src="https://cdn.jsdelivr.net/npm/cropperjs@1.6.2/dist/cropper.min.js"></script>
<script src="/assets/js/admin-add-product.js"></script>
<script src="/assets/js/main.js"></script>
</body>
</html>
