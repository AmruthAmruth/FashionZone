<%- include('../layout/header.ejs') -%>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">
</head>

<body>
    <div class="page-wrapper" style="min-height:100vh; display:flex; flex-direction:column; background:linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);">
        <%- include('../partials/navbar.ejs') -%>
        
        <main class="main" style="flex:1; display:flex; align-items:center; justify-content:center; padding:60px 24px; position:relative; overflow:hidden;">
            <div style="position:absolute; top:-30%; left:-10%; width:600px; height:600px; background:radial-gradient(circle, rgba(231,76,60,0.06) 0%, transparent 70%); pointer-events:none;"></div>
            
            <div class="card p-5 text-center" style="max-width:500px; width:90%; background:rgba(255,255,255,0.98); border-radius:24px; box-shadow:0 32px 80px rgba(0,0,0,0.4); border:1px solid rgba(255,255,255,0.1); z-index:10; margin:auto;">
                <div class="mb-4">
                    <div style="width:72px; height:72px; border-radius:50%; background:rgba(231,76,60,0.1); color:#e74c3c; font-size:2.2rem; display:inline-flex; align-items:center; justify-content:center; margin-bottom:18px; animation: bounce 1.5s ease infinite;">
                        <i class="bi bi-x-circle-fill"></i>
                    </div>
                    <h2 class="font-heading" style="font-size:2rem; font-weight:700; color:#1a1a2e; margin:0 0 6px 0;">Payment Transaction Failed</h2>
                    <p style="color:#777; font-size:14px; margin:0;">We were unable to verify or process your payment transaction.</p>
                </div>

                <div style="background:#fafafa; border:1px solid #e2e2ec; border-radius:16px; padding:20px; text-align:left; margin-bottom:30px;">
                    <div class="d-flex justify-content-between py-2 border-bottom" style="border-color:#f1f1f5 !important; font-size:13.5px;">
                        <span style="color:#777;">Order Reference:</span>
                        <strong style="color:#1a1a2e;">#<%= orderId %></strong>
                    </div>
                    <div class="d-flex justify-content-between py-2 border-bottom" style="border-color:#f1f1f5 !important; font-size:13.5px;">
                        <span style="color:#777;">Amount Due:</span>
                        <strong style="color:#e74c3c;">₹<%= totalAmount %></strong>
                    </div>
                    <div class="d-flex justify-content-between pt-2" style="font-size:13.5px;">
                        <span style="color:#777;">Method Chosen:</span>
                        <strong style="color:#1a1a2e;"><%= paymentMethod %></strong>
                    </div>
                </div>

                <div class="d-flex flex-column gap-3">
                    <form id="payment-form" class="m-0">
                        <input type="hidden" name="totalAmount" value="<%= totalAmount %>">
                        <input type="hidden" name="orderId" value="<%= orderId %>">
                        <input type="hidden" name="id" value="<%= id %>">
                        <button type="button" id="payNow" class="btn-fz-primary w-100 text-center" style="display:block; width:100% !important; padding:14px !important; margin:0 !important; cursor:pointer;">
                            Retry Payment Transaction
                        </button>
                    </form>
                    <a href="/" class="clear-link w-100 text-center" style="display:block; margin:0 !important; padding:12px !important; border-radius:50px !important; border:1.5px solid #e2e2ec !important; background:#fff !important; color:#555 !important; font-size:13px; font-weight:600; text-decoration:none; text-transform:uppercase; letter-spacing:0.5px; transition:all 0.25s ease;">
                        Return to Homepage
                    </a>
                </div>
            </div>
        </main>
        
        <%- include('../partials/footer.ejs')-%>
    </div>

    <!-- Razorpay payment retry script -->
    <link href="https://cdn.jsdelivr.net/npm/sweetalert2@11.4.12/dist/sweetalert2.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11.4.12/dist/sweetalert2.min.js"></script>
    <script src="https://checkout.razorpay.com/v1/checkout.js"></script>
    <script>
        document.getElementById("payNow").addEventListener("click", function() {
            const totalAmount = document.querySelector('input[name="totalAmount"]').value;
            const orderId = document.querySelector('input[name="orderId"]').value;
            const id = document.querySelector('input[name="id"]').value;

            Swal.fire({
                title: 'Confirm Retry',
                text: "Would you like to securely retry payment verification?",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#1a1a2e',
                cancelButtonColor: '#e74c3c',
                confirmButtonText: 'Pay Now',
                cancelButtonText: 'Cancel'
            }).then((result) => {
                if (result.isConfirmed) {
                    fetch('/ordersummany/continerazorpaypayment', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ totalAmount, orderId })
                    })
                    .then(response => response.json())
                    .then(data => {
                        if (data.success) {
                            var options = {
                                key: "rzp_test_SsN3kF1vkA34wm",
                                amount: data.amount,
                                currency: data.currency,
                                name: "FashionZone",
                                description: "Payment Retry",
                                order_id: data.orderId,
                                handler: function(response) {
                                    const { razorpay_order_id, razorpay_payment_id, razorpay_signature } = response;
                                    fetch('/verifyorderpayment', {
                                        method: 'POST',
                                        headers: { 'Content-Type': 'application/json' },
                                        body: JSON.stringify({
                                            razorpay_order_id,
                                            razorpay_payment_id,
                                            razorpay_signature,
                                            orderId
                                        })
                                    })
                                    .then(response => response.json())
                                    .then(data => {
                                        if (data.success) {
                                            Swal.fire({
                                                title: 'Success!',
                                                text: 'Your payment was successful!',
                                                icon: 'success'
                                            }).then(() => {
                                                window.location.href = `/ordersummery/${id}`;
                                            });
                                        } else {
                                            Swal.fire({
                                                title: 'Error!',
                                                text: 'Payment verification failed.',
                                                icon: 'error'
                                            });
                                        }
                                    });
                                },
                                prefill: {
                                    name: "Customer",
                                    email: "customer@example.com",
                                    contact: "1234567890"
                                },
                                theme: {
                                    color: "#1a1a2e"
                                }
                            };
                            var rzp1 = new Razorpay(options);
                            rzp1.open();
                        } else {
                            Swal.fire({
                                title: 'Error!',
                                text: 'Failed to create Razorpay order.',
                                icon: 'error'
                            });
                        }
                    });
                }
            });
        });
    </script>
</body>
</html>
