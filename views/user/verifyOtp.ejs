<%- include('../layout/header.ejs') -%>
<style>
    /* ── OTP Verification Page Styles ── */
    .otp-page-wrapper {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #1a1a2e 0%, #16213e 60%, #0f1222 100%);
        position: relative;
        overflow: hidden;
        padding: 40px 24px;
    }
    .otp-page-wrapper::before {
        content: '';
        position: absolute;
        top: -30%;
        left: -10%;
        width: 600px;
        height: 600px;
        background: radial-gradient(circle, rgba(201,169,110,0.08) 0%, transparent 70%);
        pointer-events: none;
    }
    .otp-page-wrapper::after {
        content: '';
        position: absolute;
        bottom: -20%;
        right: -10%;
        width: 500px;
        height: 500px;
        background: radial-gradient(circle, rgba(201,169,110,0.05) 0%, transparent 70%);
        pointer-events: none;
    }
    .otp-card {
        width: 100%;
        max-width: 460px;
        background: rgba(255, 255, 255, 0.98);
        border-radius: 24px;
        padding: 48px 40px;
        box-shadow: 0 32px 80px rgba(0,0,0,0.4);
        position: relative;
        z-index: 10;
        text-align: center;
    }
    .otp-logo {
        font-family: 'Playfair Display', serif;
        font-size: 2.2rem;
        font-weight: 700;
        color: #1a1a2e;
        letter-spacing: -0.5px;
        margin-bottom: 24px;
        display: inline-block;
        text-decoration: none;
    }
    .otp-logo span {
        color: #c9a96e;
    }
    .otp-title {
        font-family: 'Playfair Display', serif;
        font-size: 1.75rem;
        font-weight: 600;
        color: #1a1a2e;
        margin-bottom: 12px;
    }
    .otp-subtitle {
        font-size: 14px;
        color: #666;
        margin-bottom: 30px;
        line-height: 1.6;
    }
    .otp-alert {
        padding: 12px 16px;
        border-radius: 12px;
        font-size: 13px;
        font-weight: 500;
        margin-bottom: 24px;
        text-align: center;
        background-color: rgba(235, 94, 85, 0.08);
        border: 1px solid rgba(235, 94, 85, 0.2);
        color: #eb5e55;
    }
    .otp-form-group {
        margin-bottom: 24px;
        text-align: left;
    }
    .otp-form-group label {
        display: block;
        font-size: 12px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: #1a1a2e;
        margin-bottom: 8px;
    }
    .otp-input {
        width: 100%;
        background: #f8f9fa;
        border: 1.5px solid #e2e8f0;
        border-radius: 12px;
        padding: 14px 18px;
        font-size: 18px;
        font-weight: 600;
        letter-spacing: 4px;
        text-align: center;
        color: #1a1a2e;
        transition: all 0.25s ease;
    }
    .otp-input:focus {
        background: #fff;
        border-color: #c9a96e;
        box-shadow: 0 0 0 4px rgba(201, 169, 110, 0.15);
        outline: none;
    }
    .countdown-container {
        font-size: 14px;
        font-weight: 500;
        color: #666;
        margin: 20px 0 30px 0;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
    }
    .countdown-container i {
        color: #c9a96e;
    }
    .countdown-timer {
        color: #1a1a2e;
        font-weight: 600;
    }
    .btn-submit {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        width: 100%;
        background: #1a1a2e;
        color: #fff;
        border: none;
        border-radius: 50px;
        padding: 14px 28px;
        font-size: 14px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 1px;
        transition: all 0.25s ease;
        cursor: pointer;
        margin-bottom: 16px;
    }
    .btn-submit:hover {
        background: #c9a96e;
        transform: translateY(-2px);
        box-shadow: 0 8px 24px rgba(201, 169, 110, 0.25);
    }
    .btn-submit:active {
        transform: translateY(0);
    }
    .btn-resend {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        width: 100%;
        background: transparent;
        color: #1a1a2e;
        border: 1.5px solid #e2e8f0;
        border-radius: 50px;
        padding: 12px 28px;
        font-size: 13px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 1px;
        transition: all 0.25s ease;
        cursor: pointer;
    }
    .btn-resend:hover {
        background: #f8f9fa;
        border-color: #1a1a2e;
    }
    .oauth-divider {
        display: flex;
        align-items: center;
        margin: 32px 0 24px 0;
        color: #aaa;
        font-size: 12px;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
    .oauth-divider::before,
    .oauth-divider::after {
        content: '';
        flex: 1;
        height: 1px;
        background: #e2e8f0;
    }
    .oauth-divider::before { margin-right: 16px; }
    .oauth-divider::after { margin-left: 16px; }

    .oauth-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
    }
    .oauth-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        padding: 12px 16px;
        border: 1.5px solid #e2e8f0;
        border-radius: 50px;
        background: #fff;
        color: #4a5568;
        font-size: 13px;
        font-weight: 600;
        text-decoration: none;
        transition: all 0.25s ease;
    }
    .oauth-btn:hover {
        background: #f8f9fa;
        border-color: #cbd5e0;
        color: #1a1a2e;
        text-decoration: none;
    }
    .oauth-btn i {
        font-size: 16px;
    }
    .oauth-btn.btn-g i { color: #ea4335; }
    .oauth-btn.btn-f i { color: #1877f2; }
</style>
</head>

<div class="otp-page-wrapper">
    <div class="otp-card">
        <a href="/" class="otp-logo">Fashion<span>Zone</span></a>
        
        <h2 class="otp-title">Verify OTP</h2>
        <p class="otp-subtitle">Please enter the verification code sent to your registered email address.</p>

        <% if (message && message.length > 0) { %>
            <div class="otp-alert">
                <%= message %>
            </div>
        <% } %>

        <form action="/verifyotp" method="post">
            <div class="otp-form-group">
                <label for="otp-input-field">Verification Code</label>
                <input type="text" class="otp-input" id="otp-input-field" name="otp" required
                       maxlength="6" autocomplete="off" placeholder="••••••"
                       oninput="this.value = this.value.replace(/[^0-9]/g, '')">
            </div>

            <div class="countdown-container">
                <i class="icon-clock"></i>
                <span id="countdown" class="countdown-timer">Loading...</span>
            </div>

            <button type="submit" class="btn-submit">
                <span>Verify & Proceed</span>
                <i class="icon-long-arrow-right"></i>
            </button>
        </form>

        <form action="resendotp" method="post">
            <button type="submit" class="btn-resend">
                <i class="icon-refresh"></i>
                <span>Resend OTP</span>
            </button>
        </form>

        <div class="oauth-divider">or sign in with</div>

        <div class="oauth-row">
            <a href="/auth/google" class="oauth-btn btn-g">
                <i class="icon-google"></i>
                <span>Google</span>
            </a>
            <a href="#" class="oauth-btn btn-f">
                <i class="icon-facebook-f"></i>
                <span>Facebook</span>
            </a>
        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        const countdownElement = document.getElementById("countdown");
        const otpExpiration = <%= otpExpiration %>;
        
        const updateTime = () => {
            const now = new Date().getTime();
            const remainingTime = otpExpiration - now;

            if (remainingTime <= 0) {
                countdownElement.innerText = "Expired";
                countdownElement.style.color = "#eb5e55";
                clearInterval(timer);
                return;
            }

            const minutes = Math.floor((remainingTime % (1000 * 60 * 60)) / (1000 * 60));
            const seconds = Math.floor((remainingTime % (1000 * 60)) / 1000);

            countdownElement.innerText = `Expires in ${minutes}:${seconds < 10 ? "0" : ""}${seconds}`;
            countdownElement.style.color = "#1a1a2e";
        };
 
        updateTime();
        const timer = setInterval(updateTime, 1000);
    });
</script>