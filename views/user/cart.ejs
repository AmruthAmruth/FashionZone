<%- include('../layout/header.ejs') -%>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
</head>

<div class="page-wrapper">
    <%- include('../partials/navbar.ejs') -%>

    <main class="main">
        <div class="page-header text-center" style="background-image: url('/static/images/page-header-bg.jpg')">
            <div class="container">
                <h1 class="page-title">Your Bag<span>Your curated fashion selections.</span></h1>
            </div>
        </div>

        <nav aria-label="breadcrumb" class="breadcrumb-nav mb-4">
            <div class="container">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/">Home</a></li>
                    <li class="breadcrumb-item"><a href="/shop">Shop</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Shopping Bag</li>
                </ol>
            </div>
        </nav>

        <div class="page-content">
            <div class="cart">
                <div class="container">
                    <div class="row">
                        <div class="col-lg-9">
                            <div class="cart-table-container">
                                <table class="table table-cart m-0">
                                    <thead>
                                        <tr>
                                            <th>Product Details</th>
                                            <th class="text-center">Quantity</th>
                                            <th class="text-center">Price</th>
                                            <th class="text-center">Subtotal</th>
                                            <th class="text-center">Remove</th>
                                        </tr>
                                    </thead>
                                
                                    <tbody>
                                        <% if (userCart && userCart.items && userCart.items.length > 0) { %> 
                                            <% userCart.items.forEach(item => { %>
                                                <tr>
                                                    <td>
                                                        <div class="product-col" style="display:flex; align-items:center; gap:16px;">
                                                            <div class="product-media" style="width:70px; height:70px; border-radius:8px; overflow:hidden; border:1px solid #e2e2ec; flex-shrink:0;">
                                                                <img src="<%= item.image %>" alt="<%= item.title %>" style="width:100%; height:100%; object-fit:cover;">
                                                            </div>
                                                            <h3 class="product-title" style="font-size:14px; font-weight:600; margin:0;"><%= item.title %></h3>
                                                        </div>
                                                    </td>
                                            
                                                    <td class="text-center">
                                                        <div style="display:inline-flex; align-items:center; border:1.5px solid #e2e2ec; border-radius:50px; padding:3px; background:#f8f9fa;">
                                                            <form id="update-cart-form-<%= item.productId %>" action="/cart/update/<%= item.productId %>" method="POST" data-product-id="<%= item.productId %>" class="d-flex align-items-center m-0">
                                                                <button type="button" class="btn-outline-secondary update-cart-btn" style="width:28px; height:28px; border:none; background:none; border-radius:50%; font-weight:700; cursor:pointer;" data-action="decrease">-</button>
                                                                <input type="text" value="<%= item.quantity %>" disabled class="quantity-input mx-2" style="width:30px; border:none; background:transparent; text-align:center; font-weight:600; font-size:14px; color:#1a1a2e;">
                                                                <button type="button" class="btn-outline-secondary update-cart-btn" style="width:28px; height:28px; border:none; background:none; border-radius:50%; font-weight:700; cursor:pointer;" data-action="increase">+</button>
                                                            </form>
                                                        </div>
                                                    </td>
                                            
                                                    <td class="text-center" style="font-weight:500;">₹<%= item.price %></td>
                                                    <td class="text-center" style="font-weight:600; color:#1a1a2e;">₹<%= item.price * item.quantity %></td>
                                                    <td class="text-center">
                                                        <form action="/cart/remove/<%= item.productId %>" method="POST" class="m-0">
                                                            <button type="submit" class="btn-remove" style="border:none; cursor:pointer; background:none; margin:0 auto;"><i class="icon-close"></i></button>
                                                        </form>
                                                    </td>
                                                </tr>
                                            <% }); %>
                                        <% } else { %>
                                            <tr>
                                                <td colspan="5" class="text-center py-5">
                                                    <i class="icon-shopping-cart mb-3" style="font-size:3rem; color:#c9a96e; display:block;"></i>
                                                    <h3 style="font-family:'Playfair Display', serif; font-weight:600; color:#1a1a2e; margin-bottom:8px;">Your Bag is Empty</h3>
                                                    <p style="color:#777; font-size:14px; margin-bottom:20px;">Explore our catalog to find premium selections for your style.</p>
                                                    <a href="/shop" class="btn-fz-primary" style="display:inline-block; padding:12px 28px !important;">Shop Catalog</a>
                                                </td>
                                            </tr>
                                        <% } %>
                                    </tbody>
                                </table>
                            </div>
                        </div>

                        <aside class="col-lg-3">
                            <div class="cart-summary" style="background:#fafafa; border:1px solid #e2e2ec; padding:28px; border-radius:18px;">
                                <h3 class="summary-title" style="font-family:'Playfair Display', serif; font-size:1.3rem; font-weight:700; color:#1a1a2e; border-bottom:2px solid #c9a96e; padding-bottom:10px; margin-bottom:24px; display:inline-block;">Bag Summary</h3>
                                <form action="/checkoutfromcart" method="post" class="m-0">
                                    <table class="table table-summary m-0">
                                        <tbody>
                                            <tr class="summary-total" style="border:none;">
                                                <td style="font-size:14px; font-weight:600; color:#1a1a2e; padding:10px 0;">Total Amount:</td>
                                                <td style="font-size:18px; font-weight:700; color:#27ae60; text-align:right; padding:10px 0;">
                                                    ₹<span id="total-price"><%= cartPrice.total %></span>
                                                    <input type="hidden" name="totalPrice" value="<%= cartPrice.total %>">
                                                </td>
                                            </tr>
                                        </tbody>
                                    </table>
                                    <button type="submit" class="btn-fz-primary w-100 text-center mt-4" style="display:block; width:100% !important; padding:14px !important; margin:0 !important; cursor:pointer;">
                                        Proceed To Checkout
                                    </button>
                                </form>
                            </div>

                            <a href="/shop" class="clear-link w-100 text-center" style="display:block; margin: 16px 0 0 0 !important; padding:11px !important; border-radius:50px !important; border:1.5px solid #e2e2ec !important; background:#fff !important; color:#555 !important; font-size:13px; font-weight:600; text-decoration:none; text-transform:uppercase; letter-spacing:0.5px; transition:all 0.25s ease;">
                                <i class="icon-refresh" style="margin-right:6px;"></i> Continue Shopping
                            </a>
                        </aside>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <%- include('../partials/footer.ejs') -%>
</div>

<!-- SweetAlert & Dynamic Scripts -->
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    document.addEventListener("DOMContentLoaded", function () {
        const updateButtons = document.querySelectorAll('.update-cart-btn');
        
        updateButtons.forEach(button => {
            button.addEventListener('click', function() {
                const action = this.getAttribute('data-action');
                const form = this.closest('form');
                const productId = form.getAttribute('data-product-id');
                updateCartQuantity(productId, action);
            });
        });

        function updateCartQuantity(productId, action) {
            fetch(`/cart/update/${productId}`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({ action: action }),
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    Swal.fire({
                        icon: 'success',
                        title: 'Cart Updated',
                        text: `Quantity has been successfully updated.`,
                        confirmButtonText: 'Ok'
                    }).then(() => {
                        window.location.reload(); 
                    });
                } else {
                    Swal.fire({
                        icon: 'error',
                        title: 'Limit Exceeded',
                        text: data.message || 'Error occurred while updating the cart.',
                        confirmButtonText: 'Ok'
                    });
                }
            })
            .catch(err => {
                console.error("Error updating cart:", err);
                Swal.fire({
                    icon: 'error',
                    title: 'Oops...',
                    text: 'An error occurred while updating the cart.',
                    confirmButtonText: 'Ok'
                });
            });
        }

        const checkoutBtn = document.querySelector('.btn-fz-primary');
        if (checkoutBtn) {
            checkoutBtn.addEventListener('click', function(e) {
                const userCartItems = <% if (userCart && userCart.items) { %> <%= JSON.stringify(userCart.items) %> <% } else { %> [] <% } %>;
                if (userCartItems.length === 0) {
                    e.preventDefault();
                    Swal.fire({
                        icon: 'error',
                        title: 'Empty Bag',
                        text: 'Your bag is empty. Add items before proceeding to checkout.',
                        confirmButtonText: 'OK'
                    });
                }
            });
        }
    });
</script>
<script>
    <% if (messages.error) { %>
        Swal.fire({
            icon: 'error',
            title: 'Oops...',
            text: '<%= messages.error %>',
        });
    <% } %>
</script>
</body>
</html>