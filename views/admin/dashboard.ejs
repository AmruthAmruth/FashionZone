      <div class="card-body p-0" style="overflow-y: auto; max-height: 330px;">
        <div class="table-responsive">
          <table class="table table-hover align-middle mb-0" style="margin: 0;">
            <thead style="background: rgba(26,26,46,0.02) !important;">
              <tr>
                <th style="padding: 14px 20px !important; font-size: 11px; font-weight: 700; text-transform: uppercase; color: var(--fz-text-muted);">Rank</th>
                <th style="padding: 14px 20px !important; font-size: 11px; font-weight: 700; text-transform: uppercase; color: var(--fz-text-muted);">Product Name</th>
