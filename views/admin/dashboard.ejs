                <th style="padding: 14px 20px !important; font-size: 11px; font-weight: 700; text-transform: uppercase; color: var(--fz-text-muted);">Rank</th>
                <th style="padding: 14px 20px !important; font-size: 11px; font-weight: 700; text-transform: uppercase; color: var(--fz-text-muted);">Category</th>
