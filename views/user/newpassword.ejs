<%- include('../layout/header.ejs') -%>
<style>
    /* ── New Password Page Styles ── */
    .password-page-wrapper {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #1a1a2e 0%, #16213e 60%, #0f1222 100%);
        position: relative;
        overflow: hidden;
        padding: 40px 24px;
    }
    .password-page-wrapper::before {
        content: '';
        position: absolute;
        top: -30%;
        left: -10%;
        width: 600px;
        height: 600px;
        background: radial-gradient(circle, rgba(201,169,110,0.08) 0%, transparent 70%);
        pointer-events: none;
    }
    .password-page-wrapper::after {
        content: '';
        position: absolute;
        bottom: -20%;
        right: -10%;
        width: 500px;
        height: 500px;
        background: radial-gradient(circle, rgba(201,169,110,0.05) 0%, transparent 70%);
        pointer-events: none;
    }
    .password-card {
        width: 100%;
        max-width: 460px;
        background: rgba(255, 255, 255, 0.98);
        border-radius: 24px;
        padding: 48px 40px;
        box-shadow: 0 32px 80px rgba(0,0,0,0.4);
        position: relative;
        z-index: 10;
        text-align: center;
    }
    .password-logo {
        font-family: 'Playfair Display', serif;
        font-size: 2.2rem;
        font-weight: 700;
        color: #1a1a2e;
        letter-spacing: -0.5px;
        margin-bottom: 24px;
        display: inline-block;
        text-decoration: none;
    }
    .password-logo span {
        color: #c9a96e;
    }
    .password-title {
        font-family: 'Playfair Display', serif;
        font-size: 1.75rem;
        font-weight: 600;
        color: #1a1a2e;
        margin-bottom: 12px;
    }
    .password-subtitle {
        font-size: 14px;
        color: #666;
        margin-bottom: 30px;
        line-height: 1.6;
    }
    .password-alert {
        padding: 12px 16px;
        border-radius: 12px;
        font-size: 13px;
        font-weight: 500;
        margin-bottom: 24px;
        text-align: center;
        background-color: rgba(235, 94, 85, 0.08);
        border: 1px solid rgba(235, 94, 85, 0.2);
        color: #eb5e55;
    }
    .password-form-group {
        margin-bottom: 20px;
        text-align: left;
    }
    .password-form-group label {
        display: block;
        font-size: 12px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: #1a1a2e;
        margin-bottom: 8px;
    }
    .input-wrapper {
        position: relative;
        display: flex;
        align-items: center;
    }
    .password-input {
        width: 100%;
        background: #f8f9fa;
        border: 1.5px solid #e2e8f0;
        border-radius: 12px;
        padding: 14px 50px 14px 18px;
        font-size: 15px;
        font-weight: 500;
        color: #1a1a2e;
        transition: all 0.25s ease;
    }
    .password-input:focus {
        background: #fff;
        border-color: #c9a96e;
        box-shadow: 0 0 0 4px rgba(201, 169, 110, 0.15);
        outline: none;
    }
    .toggle-btn {
        position: absolute;
        right: 16px;
        background: none;
        border: none;
        color: #888899;
        cursor: pointer;
        padding: 4px;
        font-size: 16px;
        transition: color 0.25s ease;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .toggle-btn:hover {
        color: #1a1a2e;
    }
    .btn-submit {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        width: 100%;
        background: #1a1a2e;
        color: #fff;
        border: none;
        border-radius: 50px;
        padding: 14px 28px;
        font-size: 14px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 1px;
        transition: all 0.25s ease;
        cursor: pointer;
        margin-top: 30px;
    }
    .btn-submit:hover {
        background: #c9a96e;
        transform: translateY(-2px);
        box-shadow: 0 8px 24px rgba(201, 169, 110, 0.25);
    }
    .btn-submit:active {
        transform: translateY(0);
    }
</style>
</head>

<div class="password-page-wrapper">
    <div class="password-card">
        <a href="/" class="password-logo">Fashion<span>Zone</span></a>
        
        <h2 class="password-title">Create New Password</h2>
        <p class="password-subtitle">Please enter your new secure password below to complete the reset process.</p>

        <% if (message && message.length > 0) { %>
            <div class="password-alert">
                <%= message %>
            </div>
        <% } %>

        <form action="/resetpassword" method="post">
            <div class="password-form-group">
                <label for="newpassword">New Password</label>
                <div class="input-wrapper">
                    <input type="password" class="password-input" id="newpassword" name="newpassword" required
                           title="Password must be at least 6 characters long, contain at least one uppercase letter, one lowercase letter, one number, and one special character."
                           pattern="(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[!@#$%^&*])[A-Za-z\d!@#$%^&*]{6,}">
                    <button type="button" class="toggle-btn" tabindex="-1" onclick="togglePasswordVisibility('newpassword', this)">
                        <i class="fas fa-eye"></i>
                    </button>
                </div>
            </div>

            <div class="password-form-group">
                <label for="confirmnewPassword">Confirm Password</label>
                <div class="input-wrapper">
                    <input type="password" class="password-input" id="confirmnewPassword" name="confirmnewPassword" required
                           title="Password must match the above new password."
                           pattern="(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[!@#$%^&*])[A-Za-z\d!@#$%^&*]{6,}">
                    <button type="button" class="toggle-btn" tabindex="-1" onclick="togglePasswordVisibility('confirmnewPassword', this)">
                        <i class="fas fa-eye"></i>
                    </button>
                </div>
            </div>

            <button type="submit" class="btn-submit">
                <span>Update Password</span>
                <i class="icon-long-arrow-right"></i>
            </button>
        </form>
    </div>
</div>

<script>
    function togglePasswordVisibility(inputId, button) {
        const input = document.getElementById(inputId);
        const icon = button.querySelector("i");

        if (input.type === "password") {
            input.type = "text";
            icon.classList.remove("fa-eye");
            icon.classList.add("fa-eye-slash");
        } else {
            input.type = "password";
            icon.classList.remove("fa-eye-slash");
            icon.classList.add("fa-eye");
        }
    }
</script>
