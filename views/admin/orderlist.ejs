

<%- include('../layout/adminheader.ejs') -%>

    </head>
   <body>
   

 <!-- Layout wrapper -->
 <div class="layout-wrapper layout-content-navbar  ">
    <div class="layout-container">
  
 <!-- Menu -->
<%- include('../partials/adminsidebar.ejs') -%>


<div class="layout-page">
        
        
  
  
  
    <!-- Navbar -->
  
  <%- include('../partials/adminnavbar.ejs') -%>
  
  <!-- / Navbar -->

              <!-- Content wrapper -->
      <div class="content-wrapper">

        <!-- Content -->
        
          <div class="container-xxl flex-grow-1 container-p-y">
            
            
<!-- Order List Widget -->

<h2 class="text-center">Order List</h2>


<!-- Order List Table -->
<div class="card">
  <div class="card-datatable table-responsive">
    <table class="datatables-order table">
        <thead>
          <tr>
            <th>Order ID</th>
            <th>Date</th>
            <th>Customer</th>
            <th>Total Amount</th>
            <th>Status</th>
            <th>Payment Method</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% if (orders && orders.length > 0) { %>
          <% orders.forEach(order => { %>
            <tr>
              <td style="max-width: 200px;"><%= order.orderId %></td>
              <td><%= new Date(order.createdAt).toLocaleDateString() %></td>
              <td><%= order.user ? order.user.name : 'Unknown' %></td>
              <td>₹<%= order.totalAmount %></td>
              <td>
                <% if (order.status === 'Pending') { %>
                  <span class="status-badge status-pending">Pending</span>
                <% } else if (order.status === 'Cancelled') { %>
                  <span class="status-badge status-inactive">Cancelled</span>
                <% } else if (order.status === 'Delivered') { %>
                  <span class="status-badge status-active">Delivered</span>
                <% } else if (order.status === 'Shipped') { %>
                  <span class="status-badge status-pending">Shipped</span>
                <% } else if (order.status === 'Returned') { %>
                  <span class="status-badge status-inactive">Returned</span>
                <% } else { %>
                  <span class="status-badge"><%= order.status %></span>
                <% } %>
              </td>
              <td><%= order.paymentMethod %></td>
              <td>
                <a href="/admin/orderdetails/<%= order._id %>" class="btn btn-white border btn-sm">View</a>
                
              </td>
              
            </tr>
          <% }); %>
          <% } else { %>
            <tr>
              <td colspan="7" class="text-center py-5 admin-empty-state">No orders found yet.</td>
            </tr>
          <% } %>
        </tbody>
      </table>
      
  </div>
</div>


          </div>
          <!-- / Content -->

          
          


</div>
          
          <div class="content-backdrop fade"></div>
        </div>
        <!-- Content wrapper -->



</div>
</div>
<script src="/assets/vendor/libs/jquery/jquery.js"></script>
<script src="/assets/vendor/js/bootstrap.js"></script>
<script src="/assets/vendor/js/menu.js"></script>
<script src="/assets/js/main.js"></script>
</body>
</html>