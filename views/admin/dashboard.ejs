        <h5 class="card-title mb-0" style="font-family: var(--font-heading) !important; font-weight: 700; color: var(--fz-dark) !important; font-size: 15px;"><i class="ri-bookmark-3-line text-gold me-1"></i> Top 10 Brands</h5>
      </div>
      <div class="card-body p-0" style="overflow-y: auto; max-height: 330px;">
        <div class="table-responsive">
          <table class="table table-hover align-middle mb-0" style="margin: 0;">
            <thead style="background: rgba(26,26,46,0.02) !important;">
              <tr>
                <th style="padding: 14px 20px !important; font-size: 11px; font-weight: 700; text-transform: uppercase; color: var(--fz-text-muted);">Rank</th>
                <th style="padding: 14px 20px !important; font-size: 11px; font-weight: 700; text-transform: uppercase; color: var(--fz-text-muted);">Brand</th>
                <th style="padding: 14px 20px !important; font-size: 11px; font-weight: 700; text-transform: uppercase; color: var(--fz-text-muted);">Quantity Sold</th>
              </tr>
            </thead>
            <tbody>
              <% let brandCounter = 1; %>
              <% const brandEntries = Object.entries(brand || {}); %>
              <% if (brandEntries.length > 0) { %>
              <% for (const [brandName, quantitySold] of brandEntries) { %>
                <tr style="transition: var(--fz-transition-fast);">
                  <td style="padding: 14px 20px !important; font-weight: 700; color: var(--fz-gold-dark);"><%= brandCounter++ %></td>
                  <td style="padding: 14px 20px !important; font-weight: 600; color: var(--fz-dark);"><%= brandName %></td>
                  <td style="padding: 14px 20px !important; font-weight: 600;"><span class="badge" style="background: rgba(201,169,110,0.12) !important; color: var(--fz-gold-dark) !important; font-size: 12px; font-weight: 700; border-radius: var(--fz-radius-pill) !important; padding: 4px 12px !important;"><%= quantitySold %> units</span></td>
                </tr>
              <% } %>
              <% } else { %>
                <tr><td colspan="3" class="text-center py-4 admin-empty-state">No sales data yet</td></tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
