<%- include('../layout/header.ejs') -%>

<style>
    :root {
        --fz-primary: #c9a96e;
        --fz-primary-dark: #a8813d;
        --fz-dark: #111827;
        --fz-navy: #1a1a2e;
        --fz-soft-dark: #16213e;
        --fz-text: #6b7280;
        --fz-light: #f8f7f4;
        --fz-white: #ffffff;
        --fz-border: rgba(17, 24, 39, 0.08);
        --fz-shadow: 0 20px 50px rgba(17, 24, 39, 0.08);
        --fz-shadow-hover: 0 28px 70px rgba(17, 24, 39, 0.14);
    }

    body {
        background: #fafafa;
        color: var(--fz-dark);
        overflow-x: hidden;
    }

    .main {
        background:
            radial-gradient(circle at top left, rgba(201, 169, 110, 0.08), transparent 32%),
            linear-gradient(180deg, #ffffff 0%, #fafafa 100%);
    }

    /* Hero */
    .intro-slider-container {
        position: relative;
        overflow: hidden;
    }

    .intro-slide {
        min-height: 720px;
        background-size: cover;
        background-position: center;
        display: flex;
        align-items: center;
        position: relative;
    }

    .intro-slide::before {
        content: "";
        position: absolute;
        inset: 0;
        background:
            linear-gradient(90deg, rgba(17, 24, 39, 0.82) 0%, rgba(17, 24, 39, 0.55) 45%, rgba(17, 24, 39, 0.18) 100%),
            linear-gradient(180deg, rgba(17, 24, 39, 0.1) 0%, rgba(17, 24, 39, 0.25) 100%);
        z-index: 1;
    }

    .intro-content {
        text-align: left;
        max-width: 720px;
        position: relative;
        z-index: 5;
        padding-left: 12px;
        animation: fzFadeUp 1s cubic-bezier(0.4, 0, 0.2, 1) both;
    }

    .intro-subtitle {
        color: var(--fz-primary) !important;
        font-weight: 700 !important;
        letter-spacing: 5px !important;
        font-size: 13px !important;
        text-transform: uppercase !important;
        margin-bottom: 18px !important;
    }

    .intro-title {
        font-size: clamp(3rem, 6vw, 5.4rem) !important;
        font-weight: 800 !important;
        color: #fff !important;
        line-height: 1.05 !important;
        margin-bottom: 34px !important;
        text-shadow: 0 10px 30px rgba(0, 0, 0, 0.22);
        letter-spacing: -1.5px;
    }

    .btn-discover {
        background: linear-gradient(135deg, var(--fz-primary) 0%, var(--fz-primary-dark) 100%);
        color: #111827 !important;
        border: none !important;
        font-weight: 800;
        font-size: 13px;
        text-transform: uppercase;
        letter-spacing: 1.4px;
        padding: 17px 42px !important;
        border-radius: 999px;
        box-shadow: 0 14px 35px rgba(201, 169, 110, 0.35);
        transition: all 0.35s ease;
        display: inline-flex;
        align-items: center;
        gap: 10px;
        text-decoration: none;
    }

    .btn-discover:hover {
        transform: translateY(-4px);
        box-shadow: 0 20px 48px rgba(201, 169, 110, 0.5);
        color: #111827 !important;
    }

    /* Category Banners */
    .gender-banners {
        margin-top: -75px;
        position: relative;
        z-index: 10;
        padding-bottom: 70px;
    }

    .gender-banner-card {
        border-radius: 28px;
        overflow: hidden;
        position: relative;
        box-shadow: var(--fz-shadow);
        border: 1px solid rgba(255, 255, 255, 0.25);
        transition: all 0.45s cubic-bezier(0.4, 0, 0.2, 1);
        height: 320px;
        background: #111827;
    }

    .gender-banner-card img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 1s ease;
    }

    .gender-banner-card:hover {
        transform: translateY(-10px);
        box-shadow: var(--fz-shadow-hover);
    }

    .gender-banner-card:hover img {
        transform: scale(1.1);
    }

    .gender-banner-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(to top, rgba(17, 24, 39, 0.92) 0%, rgba(17, 24, 39, 0.45) 58%, transparent 100%);
        display: flex;
        flex-direction: column;
        justify-content: flex-end;
        padding: 42px;
    }

    .gender-subtitle {
        color: var(--fz-primary);
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 2.5px;
        margin-bottom: 8px;
    }

    .gender-title {
        font-family: 'Playfair Display', serif;
        color: #fff;
        font-size: 2rem;
        font-weight: 800;
        margin-bottom: 16px;
    }

    .gender-link {
        color: #fff;
        font-size: 13px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: all 0.3s ease;
    }

    .gender-banner-card:hover .gender-link {
        color: var(--fz-primary);
        gap: 13px;
    }

    /* Section Title */
    .section-title-wrapper {
        text-align: center;
        margin-bottom: 42px;
    }

    .section-title-wrapper h2 {
        font-family: 'Playfair Display', serif;
        font-size: clamp(2rem, 4vw, 3rem);
        font-weight: 800;
        color: var(--fz-navy);
        margin-bottom: 10px;
        letter-spacing: -0.5px;
    }

    .section-title-wrapper p {
        color: #7a7a9a;
        font-size: 15px;
        line-height: 1.8;
        max-width: 620px;
        margin: 0 auto;
    }

    /* Tabs */
    .heading.heading-center {
        margin-bottom: 34px !important;
    }

    .nav-pills {
        gap: 10px;
    }

    .nav-pills .nav-link {
        border-radius: 999px;
        padding: 11px 26px;
        color: #555;
        font-weight: 700;
        background: #fff;
        border: 1px solid var(--fz-border);
        box-shadow: 0 8px 24px rgba(17, 24, 39, 0.04);
        transition: all 0.3s ease;
    }

    .nav-pills .nav-link:hover {
        color: var(--fz-primary-dark);
        transform: translateY(-2px);
    }

    .nav-pills .nav-link.active {
        background: var(--fz-navy);
        color: #fff;
        border-color: var(--fz-navy);
        box-shadow: 0 14px 34px rgba(17, 24, 39, 0.18);
    }

    /* Product Cards */
    .product.product-7 {
        background: #fff;
        border-radius: 24px;
        overflow: hidden;
        border: 1px solid var(--fz-border);
        box-shadow: 0 12px 32px rgba(17, 24, 39, 0.05);
        transition: all 0.4s ease;
    }

    .product.product-7:hover {
        transform: translateY(-10px);
        box-shadow: var(--fz-shadow-hover);
    }

    .product-media {
        border-radius: 24px 24px 0 0;
        overflow: hidden;
        background: #f4f4f4;
    }

    .product-media img {
        transition: transform 0.75s ease;
    }

    .product.product-7:hover .product-image {
        transform: scale(1.08);
    }

    .product-body {
        padding: 20px 18px 24px !important;
    }

    .product-cat a {
        color: #9ca3af;
        font-size: 12px;
        letter-spacing: 1px;
        text-transform: uppercase;
        font-weight: 700;
    }

    .product-title {
        font-size: 15px !important;
        font-weight: 700 !important;
        line-height: 1.45 !important;
        min-height: 42px;
    }

    .product-title a {
        color: var(--fz-dark);
        transition: color 0.3s ease;
    }

    .product-title a:hover {
        color: var(--fz-primary-dark);
    }

    .product-price {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 8px;
        font-size: 17px;
        font-weight: 800;
        color: var(--fz-navy);
    }

    .new-price {
        color: var(--fz-navy);
        font-weight: 800;
    }

    .old-price {
        color: #9ca3af;
        text-decoration: line-through;
        font-size: 14px;
    }

    .product-label {
        border-radius: 999px;
        padding: 6px 12px;
        font-weight: 800;
        font-size: 11px;
        letter-spacing: 0.5px;
        text-transform: uppercase;
    }

    .product-action {
        background: rgba(255, 255, 255, 0.96);
        backdrop-filter: blur(10px);
    }

    .btn-product.btn-cart span {
        font-weight: 800;
        letter-spacing: 0.8px;
    }

    .btn-product-icon.btn-wishlist {
        width: 42px;
        height: 42px;
        border-radius: 50% !important;
        background: #fff !important;
        box-shadow: 0 10px 25px rgba(17, 24, 39, 0.12);
        transition: all 0.3s ease;
    }

    .btn-product-icon.btn-wishlist:hover {
        background: var(--fz-primary) !important;
        color: var(--fz-navy) !important;
        transform: scale(1.08);
    }

    /* Features Strip */
    .features-strip {
        background:
            radial-gradient(circle at top left, rgba(201, 169, 110, 0.14), transparent 35%),
            linear-gradient(135deg, var(--fz-navy) 0%, var(--fz-soft-dark) 100%);
        border-top: 1px solid rgba(201, 169, 110, 0.15);
        border-bottom: 1px solid rgba(201, 169, 110, 0.15);
        padding: 58px 0;
        margin: 85px 0;
        position: relative;
        overflow: hidden;
    }

    .feature-item {
        text-align: center;
        padding: 24px 18px;
        transition: all 0.35s ease;
    }

    .feature-item:hover {
        transform: translateY(-8px);
    }

    .feature-icon-wrapper {
        width: 70px;
        height: 70px;
        border-radius: 50%;
        background: rgba(201, 169, 110, 0.11);
        border: 1px solid rgba(201, 169, 110, 0.3);
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 22px;
        font-size: 27px;
        color: var(--fz-primary);
        transition: all 0.35s ease;
    }

    .feature-item:hover .feature-icon-wrapper {
        background: var(--fz-primary);
        color: var(--fz-navy);
        transform: translateY(-5px) rotate(4deg);
        box-shadow: 0 12px 32px rgba(201, 169, 110, 0.35);
    }

    .feature-title {
        color: #fff;
        font-size: 15px;
        font-weight: 800;
        margin-bottom: 8px;
    }

    .feature-desc {
        color: rgba(255, 255, 255, 0.58);
        font-size: 13px;
        line-height: 1.7;
        margin: 0;
    }

    /* Brands */
    .brands {
        background: #fff;
        border-radius: 28px;
        padding: 46px 34px !important;
        border: 1px solid var(--fz-border);
        box-shadow: 0 12px 38px rgba(17, 24, 39, 0.05);
    }

    .brand {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 70px;
        opacity: 0.58;
        filter: grayscale(1);
        transition: all 0.3s ease;
    }

    .brand:hover {
        opacity: 1;
        filter: grayscale(0);
        transform: translateY(-4px);
    }

    /* Newsletter */
    .newsletter .banner,
    .newsletter .cta-box {
        box-shadow: var(--fz-shadow);
        border: 1px solid var(--fz-border);
    }

    .newsletter .banner {
        transition: all 0.4s ease;
    }

    .newsletter .banner:hover {
        transform: translateY(-6px);
        box-shadow: var(--fz-shadow-hover);
    }

    .newsletter .banner img {
        transition: transform 0.9s ease;
    }

    .newsletter .banner:hover img {
        transform: scale(1.08);
    }

    .cta.cta-box {
        background:
            radial-gradient(circle at top right, rgba(201, 169, 110, 0.13), transparent 36%),
            #fff;
        padding: 54px;
        display: flex;
        align-items: center;
    }

    .cta-title {
        font-family: 'Playfair Display', serif;
        font-size: 2.2rem;
        font-weight: 800;
        color: var(--fz-navy);
        margin-bottom: 16px;
    }

    .newsletter-form .form-control {
        height: 58px;
        border: 1px solid rgba(17, 24, 39, 0.1);
        padding-left: 22px;
        box-shadow: none;
    }

    .newsletter-form .form-control:focus {
        border-color: var(--fz-primary);
    }

    .newsletter-form .btn {
        height: 58px;
        font-weight: 800;
        letter-spacing: 0.8px;
        transition: all 0.3s ease;
    }

    .newsletter-form .btn:hover {
        background: var(--fz-primary) !important;
        color: var(--fz-navy) !important;
    }

    .more-container .btn {
        border-radius: 999px;
        padding: 14px 34px;
        font-weight: 800;
        letter-spacing: 0.8px;
        transition: all 0.35s ease;
    }

    .more-container .btn:hover {
        transform: translateY(-4px);
        box-shadow: 0 16px 35px rgba(17, 24, 39, 0.13);
    }

    /* Reveal Animation */
    .fz-reveal {
        opacity: 0;
        transform: translateY(34px);
        transition: opacity 0.8s ease, transform 0.8s ease;
    }

    .fz-reveal.fz-show {
        opacity: 1;
        transform: translateY(0);
    }

    @keyframes fzFadeUp {
        from {
            opacity: 0;
            transform: translateY(35px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* Responsive */
    @media (max-width: 991px) {
        .intro-slide {
            min-height: 620px;
        }

        .gender-banners {
            margin-top: -45px;
        }

        .gender-banner-card {
            height: 285px;
        }

        .features-strip {
            margin: 65px 0;
        }

        .cta.cta-box {
            padding: 42px;
        }
    }

    @media (max-width: 575px) {
        .intro-slide {
            min-height: 560px;
        }

        .intro-content {
            padding-left: 0;
        }

        .intro-subtitle {
            letter-spacing: 3px !important;
            font-size: 11px !important;
        }

        .intro-title {
            font-size: 3rem !important;
        }

        .btn-discover {
            padding: 14px 28px !important;
            font-size: 12px;
        }

        .gender-banner-card {
            height: 250px;
            border-radius: 22px;
        }

        .gender-banner-overlay {
            padding: 30px;
        }

        .section-title-wrapper {
            margin-bottom: 30px;
        }

        .nav-pills .nav-link {
            padding: 10px 18px;
            font-size: 13px;
        }

        .cta.cta-box {
            padding: 32px 24px;
        }

        .cta-title {
            font-size: 1.8rem;
        }

        .newsletter-form .input-group {
            display: block;
        }

        .newsletter-form .form-control {
            border-radius: 50px !important;
            margin-bottom: 12px;
        }

        .newsletter-form .input-group-append {
            width: 100%;
        }

        .newsletter-form .btn {
            width: 100%;
            border-radius: 50px !important;
        }
    }
</style>
</head>

<body>
    <div class="page-wrapper">
        <%- include('../partials/navbar.ejs') -%>

        <main class="main">
            <!-- Hero Slider -->
            <div class="intro-slider-container">
                <div class="intro-slider owl-carousel owl-theme owl-nav-inside owl-light" data-toggle="owl" data-owl-options='{
                        "dots": true,
                        "nav": false, 
                        "responsive": {
                            "992": {
                                "nav": true,
                                "dots": false
                            }
                        }
                    }'>
                    <div class="intro-slide" style="background-image: url(/static/images/banners/banner-fullwidth.jpg);">
                        <div class="container d-flex align-items-center">
                            <div class="intro-content">
                                <h3 class="intro-subtitle">Summer Collection 2026</h3>
                                <h1 class="intro-title">Explore Premium<br>Fashion Trends</h1>
                                <a href="/shop" class="btn-discover">
                                    <span>Discover Collection</span>
                                    <i class="icon-long-arrow-right"></i>
                                </a>
                            </div>
                        </div>
                    </div>

                    <div class="intro-slide" style="background-image: url(/static/images/banners/mybanner1.jpg);">
                        <div class="container d-flex align-items-center">
                            <div class="intro-content">
                                <h3 class="intro-subtitle">Exclusive Accessories</h3>
                                <h1 class="intro-title">Curated Pieces<br>For Every Style</h1>
                                <a href="/shop" class="btn-discover">
                                    <span>Discover More</span>
                                    <i class="icon-long-arrow-right"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
                <span class="slider-loader"></span>
            </div>

            <!-- Gender Categories Banners -->
            <div class="container gender-banners fz-reveal">
                <div class="row">
                    <div class="col-sm-6 mb-4 mb-sm-0">
                        <div class="gender-banner-card">
                            <img src="/static/images/demos/demo-6/banners/banner-1.jpg" alt="Women's Fashion">
                            <div class="gender-banner-overlay">
                                <span class="gender-subtitle">New In Season</span>
                                <h3 class="gender-title">Women’s Edit</h3>
                                <a href="/shop/sort/women" class="gender-link">
                                    <span>Shop Now</span>
                                    <i class="icon-long-arrow-right"></i>
                                </a>
                            </div>
                        </div>
                    </div>

                    <div class="col-sm-6">
                        <div class="gender-banner-card">
                            <img src="/static/images/demos/demo-6/banners/banner-2.jpg" alt="Men's Fashion">
                            <div class="gender-banner-overlay">
                                <span class="gender-subtitle">New In Season</span>
                                <h3 class="gender-title">Men’s Essentials</h3>
                                <a href="/shop/sort/men" class="gender-link">
                                    <span>Shop Now</span>
                                    <i class="icon-long-arrow-right"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Trending Products Section -->
            <div class="container mb-5 fz-reveal">
                <div class="section-title-wrapper">
                    <h2>Trending Products</h2>
                    <p>Discover the most loved pieces from our current collection, curated carefully for your wardrobe.</p>
                </div>

                <div class="heading heading-center mb-3 border-0">
                    <ul class="nav nav-pills justify-content-center" role="tablist">
                        <li class="nav-item">
                            <a class="nav-link active" id="trending-all-link" data-toggle="tab" href="#trending-all-tab" role="tab" aria-controls="trending-all-tab" aria-selected="true">All Collection</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" id="trending-women-link" data-toggle="tab" href="#trending-women-tab" role="tab" aria-controls="trending-women-tab" aria-selected="false">Women</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" id="trending-men-link" data-toggle="tab" href="#trending-men-tab" role="tab" aria-controls="trending-men-tab" aria-selected="false">Men</a>
                        </li>
                    </ul>
                </div>

                <div class="tab-content tab-content-carousel">
                    <!-- Tab All -->
                    <div class="tab-pane p-0 fade show active" id="trending-all-tab" role="tabpanel" aria-labelledby="trending-all-link">
                        <div class="owl-carousel owl-simple carousel-equal-height carousel-with-shadow" data-toggle="owl"
                            data-owl-options='{
                                "nav": false, 
                                "dots": true,
                                "margin": 20,
                                "loop": false,
                                "responsive": {
                                    "0": {"items":2},
                                    "480": {"items":2},
                                    "768": {"items":3},
                                    "992": {"items":4},
                                    "1200": {"items":4, "nav": true, "dots": false}
                                }
                            }'>
                            <% allProducts.forEach(product => { %>
                                <div class="product product-7 text-center">
                                    <figure class="product-media">
                                        <span class="product-label label-sale">Sale</span>
                                        <a href="<%= product.url || '/product/' + product._id %>">
                                            <img src="<%= product.images[0] %>" alt="<%= product.title %>" class="product-image">
                                            <img src="<%= product.images[1] || product.images[0] %>" alt="<%= product.title %>" class="product-image-hover">
                                        </a>
                                        <div class="product-action-vertical">
                                            <form action="/wishlist" method="POST" style="margin:0;">
                                                <input type="hidden" name="productId" value="<%= product._id %>">
                                                <button type="submit" class="btn-product-icon btn-wishlist" style="border:none; cursor:pointer;" title="Add to wishlist">
                                                    <i class="icon-heart-o"></i>
                                                </button>
                                            </form>
                                        </div>
                                        <div class="product-action">
                                            <form action="/cart/add/<%= product._id %>" method="POST" style="width:100%; margin:0;">
                                                <button type="submit" class="btn-product btn-cart" style="width:100%; border:none; background:none; cursor:pointer;">
                                                    <span>add to cart</span>
                                                </button>
                                            </form>
                                        </div>
                                    </figure>
                                    <div class="product-body">
                                        <div class="product-cat">
                                            <a href="#"><%= product.category %></a>
                                        </div>
                                        <h3 class="product-title"><a href="<%= product.url || '/product/' + product._id %>"><%= product.title %></a></h3>
                                        <div class="product-price">
                                            <span class="new-price">₹<%= product.disPrice %></span>
                                            <span class="old-price">₹<%= product.price %></span>
                                        </div>
                                    </div>
                                </div>
                            <% }); %>
                        </div>
                    </div>

                    <!-- Tab Women -->
                    <div class="tab-pane p-0 fade" id="trending-women-tab" role="tabpanel" aria-labelledby="trending-women-link">
                        <div class="owl-carousel owl-simple carousel-equal-height carousel-with-shadow" data-toggle="owl"
                            data-owl-options='{
                                "nav": false, 
                                "dots": true,
                                "margin": 20,
                                "loop": false,
                                "responsive": {
                                    "0": {"items":2},
                                    "480": {"items":2},
                                    "768": {"items":3},
                                    "992": {"items":4},
                                    "1200": {"items":4, "nav": true, "dots": false}
                                }
                            }'>
                            <% womenProducts.forEach(product => { %>
                                <div class="product product-7 text-center">
                                    <figure class="product-media">
                                        <span class="product-label label-sale">Sale</span>
                                        <a href="<%= product.url || '/product/' + product._id %>">
                                            <img src="<%= product.images[0] %>" alt="<%= product.title %>" class="product-image">
                                            <img src="<%= product.images[1] || product.images[0] %>" alt="<%= product.title %>" class="product-image-hover">
                                        </a>
                                        <div class="product-action-vertical">
                                            <form action="/wishlist" method="POST" style="margin:0;">
                                                <input type="hidden" name="productId" value="<%= product._id %>">
