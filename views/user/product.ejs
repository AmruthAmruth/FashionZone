<%- include('../layout/header.ejs') -%>

<style>
    :root {
        --primary: #c9a96e;
        --primary-dark: #a8813d;
        --dark: #111827;
        --navy: #1a1a2e;
        --text: #6b7280;
        --muted: #9ca3af;
        --light: #f8f7f4;
        --border: rgba(17, 24, 39, 0.1);
        --shadow: 0 18px 45px rgba(17, 24, 39, 0.08);
        --shadow-hover: 0 28px 70px rgba(17, 24, 39, 0.14);
    }

    body {
        background: #fafafa;
        color: var(--dark);
    }

    .main {
        background:
            radial-gradient(circle at top left, rgba(201, 169, 110, 0.08), transparent 32%),
            linear-gradient(180deg, #ffffff 0%, #fafafa 100%);
        padding-bottom: 70px;
    }

    .breadcrumb-nav {
        background: #fff;
        border-bottom: 1px solid var(--border) !important;
        padding: 14px 0;
        margin-bottom: 40px !important;
    }

    .breadcrumb {
        margin-bottom: 0;
    }

    .product-details-card {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: 30px;
        box-shadow: var(--shadow);
        padding: 30px;
    }

    .product-gallery-card {
        border-radius: 26px;
        overflow: hidden;
        border: 1px solid var(--border);
        box-shadow: 0 14px 35px rgba(17, 24, 39, 0.06);
        background: #f7f7f7;
    }

    .product-main-image {
        position: relative;
        width: 100%;
        height: 540px;
        overflow: hidden;
        background: #f6f6f6;
    }

    #product-zoom {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.18s ease-out;
        transform-origin: center center;
    }

    .product-image-gallery {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 14px;
        margin-top: 18px;
    }

    .product-gallery-item {
        border-radius: 18px;
        overflow: hidden;
        border: 2px solid transparent;
        aspect-ratio: 1 / 1;
        transition: all 0.3s ease;
        background: #fff;
        box-shadow: 0 8px 22px rgba(17, 24, 39, 0.06);
        padding: 4px;
    }

    .product-gallery-item img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        border-radius: 14px;
    }

    .product-gallery-item.active,
    .product-gallery-item:hover {
        border-color: var(--primary);
        transform: translateY(-4px);
        box-shadow: 0 14px 30px rgba(201, 169, 110, 0.22);
    }

    .product-details-panel {
        padding: 10px 10px 10px 28px;
        height: 100%;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    .brand-tag {
        display: inline-flex;
        width: fit-content;
        padding: 8px 14px;
        border-radius: 999px;
        background: rgba(201, 169, 110, 0.12);
        color: var(--primary-dark);
        font-size: 11px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        margin-bottom: 16px;
    }

    .single-product-title {
        font-family: 'Playfair Display', serif;
        font-size: clamp(2rem, 4vw, 3rem);
        line-height: 1.15;
        font-weight: 800;
        color: var(--navy);
        margin-bottom: 14px;
        letter-spacing: -0.5px;
    }

    .ratings-container {
        margin-bottom: 20px;
    }

    .ratings-text {
        font-size: 13px;
        color: var(--text);
        text-decoration: none;
        margin-left: 8px;
    }

    .product-price {
        display: flex;
        align-items: baseline;
        gap: 14px;
        margin: 18px 0 24px 0;
    }

    .discounted-price {
        font-size: 2.4rem;
        color: #16a34a;
        font-weight: 900;
        letter-spacing: -0.5px;
    }

    .original-price {
        text-decoration: line-through;
        color: var(--muted);
        font-size: 1.15rem;
        font-weight: 600;
    }

    .product-content {
        border-top: 1px solid var(--border);
        border-bottom: 1px solid var(--border);
        padding: 22px 0;
        margin-bottom: 24px;
    }

    .product-content p {
        font-size: 15px;
        line-height: 1.8;
        color: var(--text);
        margin: 0;
    }

    .product-meta-box {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 14px;
        margin-top: 8px;
    }

    .product-meta-item {
        background: #fafafa;
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 14px 16px;
        font-size: 13.5px;
        color: var(--text);
    }

    .product-meta-item strong {
        display: block;
        color: var(--navy);
        font-weight: 800;
        margin-bottom: 5px;
    }

    .stock-success {
        color: #16a34a;
        font-weight: 800;
    }

    .stock-danger {
        color: #dc2626;
        font-weight: 800;
    }

    .action-row {
        display: flex;
        flex-wrap: wrap;
        gap: 16px;
        margin-top: 34px;
        align-items: flex-end;
    }

    .qty-label {
        font-size: 12px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: var(--navy);
        margin-bottom: 8px;
        display: block;
    }

    .qty-stepper {
        display: flex;
        align-items: center;
        border: 1.5px solid #e5e7eb;
        border-radius: 999px;
        background: #fff;
        overflow: hidden;
        padding: 5px;
        width: 150px;
        box-shadow: 0 8px 22px rgba(17, 24, 39, 0.05);
    }

    .qty-btn {
        background: #f3f4f6;
        border: none;
        width: 38px;
        height: 38px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--navy);
        font-weight: 800;
        cursor: pointer;
        border-radius: 50%;
        transition: all 0.25s ease;
    }

    .qty-btn:hover {
        background: var(--primary);
        color: var(--navy);
    }

    .qty-input-field {
        width: 54px;
        border: none;
        background: transparent;
        text-align: center;
        font-weight: 800;
        font-size: 15px;
        color: var(--navy);
        outline: none;
    }

    .btn-fz-primary {
        border: none;
        border-radius: 999px;
        background: linear-gradient(135deg, var(--primary), var(--primary-dark));
        color: var(--navy) !important;
        font-size: 13px;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 0.9px;
        transition: all 0.3s ease;
        box-shadow: 0 14px 34px rgba(201, 169, 110, 0.28);
    }

    .btn-fz-primary:hover {
        transform: translateY(-4px);
        box-shadow: 0 20px 48px rgba(201, 169, 110, 0.42);
    }

    .wishlist-btn {
        display: block;
        width: 100%;
        padding: 14px !important;
        border-radius: 999px !important;
        border: 1.5px solid #e5e7eb !important;
        background: #fff !important;
        color: var(--navy) !important;
        font-size: 13px;
        font-weight: 800;
        text-decoration: none;
        text-transform: uppercase;
        letter-spacing: 0.6px;
        transition: all 0.3s ease;
        cursor: pointer;
    }

    .wishlist-btn:hover {
        border-color: var(--primary) !important;
        background: rgba(201, 169, 110, 0.08) !important;
        transform: translateY(-3px);
    }

    .related-section {
        margin-top: 70px;
        padding-top: 55px;
        border-top: 1px solid var(--border);
    }

    .related-title {
        font-family: 'Playfair Display', serif;
        font-size: 2.3rem;
        font-weight: 800;
        color: var(--navy);
        margin-bottom: 40px;
    }

    .product.product-7 {
        background: #fff;
        border-radius: 24px;
        overflow: hidden;
        border: 1px solid var(--border);
        box-shadow: 0 12px 32px rgba(17, 24, 39, 0.05);
        transition: all 0.35s ease;
    }

    .product.product-7:hover {
        transform: translateY(-10px);
        box-shadow: var(--shadow-hover);
    }

    .product-media {
        border-radius: 24px 24px 0 0;
        overflow: hidden;
        background: #f4f4f4;
    }

    .product-image {
        transition: transform 0.75s ease;
    }

    .product.product-7:hover .product-image {
        transform: scale(1.08);
    }

    .product-body {
        padding: 20px 18px 24px !important;
    }

    .product-cat a {
        color: var(--muted);
        font-size: 12px;
        letter-spacing: 1px;
        text-transform: uppercase;
        font-weight: 800;
    }

    .product-title {
        font-size: 15px !important;
        font-weight: 800 !important;
        line-height: 1.45 !important;
        min-height: 42px;
    }

    .product-title a {
        color: var(--dark);
        transition: color 0.3s ease;
    }

    .product-title a:hover {
        color: var(--primary-dark);
    }

    .product.product-7 .product-price {
        justify-content: center;
        font-size: 17px;
        font-weight: 800;
        color: var(--navy);
        margin: 8px 0 0;
    }

    .product-label {
        border-radius: 999px;
        padding: 7px 12px;
        font-weight: 800;
        font-size: 11px;
        letter-spacing: 0.5px;
        text-transform: uppercase;
    }

    .btn-product-icon {
        width: 42px;
        height: 42px;
        border-radius: 50% !important;
        background: #fff !important;
        box-shadow: 0 10px 25px rgba(17, 24, 39, 0.12);
        transition: all 0.3s ease;
    }

    .btn-product-icon:hover {
        background: var(--primary) !important;
        color: var(--navy) !important;
        transform: scale(1.08);
    }

    .product-action {
        background: rgba(255, 255, 255, 0.96);
        backdrop-filter: blur(10px);
    }

    .btn-product.btn-cart span {
        font-weight: 800;
        letter-spacing: 0.8px;
    }

    @media (max-width: 991px) {
        .product-details-panel {
            padding: 30px 0 0;
        }

        .product-main-image {
            height: 470px;
        }
    }

    @media (max-width: 575px) {
        .product-details-card {
            padding: 18px;
            border-radius: 22px;
        }

        .product-main-image {
            height: 390px;
        }

        .product-image-gallery {
            gap: 10px;
        }

        .product-meta-box {
            grid-template-columns: 1fr;
        }

        .discounted-price {
            font-size: 2rem;
        }

        .action-row {
            display: block;
        }

        .qty-stepper {
            width: 100%;
            justify-content: space-between;
            margin-bottom: 16px;
        }

        .btn-fz-primary {
            width: 100%;
        }
    }
</style>
</head>

<body>
    <div class="page-wrapper">
        <%- include('../partials/navbar.ejs') -%>

        <main class="main">
            <nav aria-label="breadcrumb" class="breadcrumb-nav border-0 mb-4">
                <div class="container">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a href="/">Home</a></li>
                        <li class="breadcrumb-item"><a href="/shop">Shop</a></li>
                        <li class="breadcrumb-item active" aria-current="page"><%= product.title %></li>
                    </ol>
                </div>
            </nav>

            <div class="page-content">
                <div class="container">
                    <div class="product-details-card">
                        <div class="row align-items-center">
                            <div class="col-lg-6 mb-4 mb-lg-0">
                                <div class="product-gallery-card">
                                    <div class="product-main-image">
                                        <img id="product-zoom" src="/<%= product.images[0] %>" alt="<%= product.title %>">
                                    </div>
                                </div>

                                <div id="product-zoom-gallery" class="product-image-gallery">
                                    <a class="product-gallery-item active" href="#" data-image="/<%= product.images[0] %>">
                                        <img src="/<%= product.images[0] %>" alt="Product image 1">
                                    </a>

                                    <% if (product.images[1]) { %>
                                        <a class="product-gallery-item" href="#" data-image="/<%= product.images[1] %>">
                                            <img src="/<%= product.images[1] %>" alt="Product image 2">
                                        </a>
                                    <% } %>

                                    <% if (product.images[2]) { %>
                                        <a class="product-gallery-item" href="#" data-image="/<%= product.images[2] %>">
                                            <img src="/<%= product.images[2] %>" alt="Product image 3">
                                        </a>
                                    <% } %>

                                    <% if (product.images[3]) { %>
                                        <a class="product-gallery-item" href="#" data-image="/<%= product.images[3] %>">
                                            <img src="/<%= product.images[3] %>" alt="Product image 4">
                                        </a>
                                    <% } %>
                                </div>
                            </div>

                            <div class="col-lg-6">
                                <div class="product-details-panel">
                                    <span class="brand-tag"><%= product.brand %></span>

                                    <h1 class="single-product-title"><%= product.title %></h1>

                                    <div class="ratings-container">
                                        <div class="ratings">
                                            <div class="ratings-val" style="width: 80%;"></div>
                                        </div>
                                        <a class="ratings-text" href="#">( 2 Client Reviews )</a>
                                    </div>

                                    <div class="product-price">
                                        <span class="discounted-price">₹<%= product.disPrice %></span>
                                        <span class="original-price">₹<%= product.price %></span>
                                    </div>

                                    <div class="product-content">
                                        <p><%= product.description %></p>
                                    </div>

                                    <div class="product-meta-box">
                                        <div class="product-meta-item">
                                            <strong>Category</strong>
                                            <span><%= product.category %></span>
                                        </div>

                                        <div class="product-meta-item">
                                            <strong>Available Color</strong>
                                            <span><%= product.color %></span>
                                        </div>

                                        <div class="product-meta-item">
                                            <strong>Size</strong>
                                            <span><%= product.size %></span>
                                        </div>

                                        <div class="product-meta-item">
                                            <strong>Inventory Status</strong>
                                            <% if (product.stock === 0) { %>
                                                <span class="stock-danger">Out of Stock</span>
                                            <% } else { %>
                                                <span class="stock-success">In Stock (<%= product.stock %> items left)</span>
                                            <% } %>
                                        </div>
                                    </div>

                                    <% if (product.stock > 0) { %>
                                        <form action="/cart/add/<%= product._id %>" method="POST" id="add-to-cart-form">
                                            <div class="action-row">
                                                <div>
                                                    <span class="qty-label">Quantity</span>

                                                    <div class="qty-stepper">
                                                        <button type="button" class="qty-btn" onclick="adjustQty(-1)">
                                                            <i class="icon-minus"></i>
                                                        </button>

                                                        <input type="text" name="quantity" value="1" readonly class="qty-input-field" id="quantity-input">

                                                        <button type="button" class="qty-btn" onclick="adjustQty(1)">
                                                            <i class="icon-plus"></i>
                                                        </button>
                                                    </div>
                                                </div>

                                                <button type="submit" class="btn-fz-primary" style="flex:1; min-width:220px; padding:16px 36px !important; margin:0 !important; cursor:pointer; height:54px; display:inline-flex; align-items:center; justify-content:center; gap:10px;">
                                                    <i class="icon-shopping-cart"></i>
                                                    <span>Add To Bag</span>
                                                </button>
                                            </div>
                                        </form>

                                        <form id="wishlist-form" method="POST" action="/wishlist" class="mt-3">
                                            <input type="hidden" name="productId" value="<%= product._id %>">

                                            <button type="submit" class="wishlist-btn text-center">
                                                <i class="icon-heart-o" style="margin-right:6px;"></i>
                                                Add To Wishlist
                                            </button>
                                        </form>
                                    <% } %>
                                </div>
                            </div>
                        </div>
                    </div>

                    <% if (relatedProducts && relatedProducts.length > 0) { %>
                        <div class="related-section">
                            <h2 class="related-title text-center">You May Also Like</h2>

                            <div class="owl-carousel owl-simple carousel-equal-height carousel-with-shadow" data-toggle="owl"
                                data-owl-options='{
                                    "nav": false, 
                                    "dots": true,
                                    "margin": 20,
                                    "loop": false,
                                    "responsive": {
                                        "0": {"items":1},
                                        "480": {"items":2},
                                        "768": {"items":3},
                                        "992": {"items":4},
                                        "1200": {"items":4, "nav": true, "dots": false}
                                    }
                                }'>
                                <% relatedProducts.forEach(prod => { %>
                                    <div class="product product-7 text-center">
                                        <figure class="product-media">
                                            <% if (prod.stock === 0) { %>
                                                <span class="product-label bg-danger text-white">Out Of Stock</span>
                                            <% } %>

                                            <a href="/product/<%= prod._id %>?category=<%= prod.category %>">
                                                <img src="/<%= prod.images[0] %>" alt="<%= prod.title %>" class="product-image">
                                            </a>

                                            <div class="product-action-vertical">
                                                <form method="POST" action="/wishlist" style="margin:0;">
                                                    <input type="hidden" name="productId" value="<%= prod._id %>">

                                                    <button type="submit" class="btn-product-icon btn-wishlist" style="border: none; cursor:pointer;">
                                                        <i class="icon-heart-o"></i>
                                                    </button>
                                                </form>
                                            </div>

                                            <% if (prod.stock > 0) { %>
                                                <div class="product-action d-flex justify-content-center">
                                                    <form action="/cart/add/<%= prod._id %>" method="POST" style="width:100%; margin:0;">
                                                        <button type="submit" class="btn-product btn-cart" style="width:100%; border: none; background:none; cursor:pointer;">
                                                            <span>Add to cart</span>
                                                        </button>
                                                    </form>
                                                </div>
                                            <% } %>
                                        </figure>

                                        <div class="product-body">
                                            <div class="product-cat">
                                                <a href="/shop?category=<%= prod.category %>"><%= prod.category %></a>
                                            </div>

                                            <h3 class="product-title">
                                                <a href="/product/<%= prod._id %>?category=<%= prod.category %>"><%= prod.title %></a>
                                            </h3>

                                            <div class="product-price">
                                                ₹<%= prod.price %>
                                            </div>
                                        </div>
                                    </div>
                                <% }) %>
                            </div>
                        </div>
                    <% } %>
                </div>
            </div>
        </main>

        <%- include('../partials/footer.ejs') -%>
    </div>

    <button id="scroll-top" title="Back to Top"><i class="icon-arrow-up"></i></button>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        const quantityInput = document.getElementById('quantity-input');
        const stock = <%= product.stock || 0 %>;
        const maxLimit = Math.min(5, stock);

        function adjustQty(amount) {
            if (!quantityInput) return;

            let currentVal = parseInt(quantityInput.value) || 1;
            let newVal = currentVal + amount;

            if (newVal < 1) newVal = 1;

            if (newVal > maxLimit) {
                newVal = maxLimit;

                Swal.fire({
                    title: 'Limit Reached',
                    text: `Only up to ${maxLimit} units can be added to your bag.`,
                    icon: 'warning',
                    confirmButtonText: 'Okay'
                });
            }

            quantityInput.value = newVal;
        }

        document.addEventListener("DOMContentLoaded", function () {
            const zoomContainer = document.querySelector(".product-main-image");
            const zoomImage = document.getElementById("product-zoom");

            if (zoomContainer && zoomImage) {
                zoomContainer.addEventListener("mousemove", function (e) {
                    const rect = zoomContainer.getBoundingClientRect();
                    const x = e.clientX - rect.left;
                    const y = e.clientY - rect.top;

                    const xPercent = (x / rect.width) * 100;
                    const yPercent = (y / rect.height) * 100;

                    zoomImage.style.transformOrigin = `${xPercent}% ${yPercent}%`;
                    zoomImage.style.transform = "scale(2.15)";
                });

                zoomContainer.addEventListener("mouseleave", function () {
                    zoomImage.style.transform = "scale(1)";
                    zoomImage.style.transformOrigin = "center center";
                });
            }

            const mainImg = document.getElementById('product-zoom');
            const thumbs = document.querySelectorAll('.product-gallery-item');

            thumbs.forEach(thumb => {
                thumb.addEventListener('click', function (e) {
                    e.preventDefault();

                    thumbs.forEach(t => t.classList.remove('active'));
                    this.classList.add('active');

                    const newSrc = this.getAttribute('data-image');

                    if (mainImg) {
                        mainImg.style.opacity = "0";

                        setTimeout(() => {
                            mainImg.setAttribute('src', newSrc);
                            mainImg.style.opacity = "1";
                        }, 120);
                    }
                });
            });

            const cartForm = document.getElementById('add-to-cart-form');

            if (cartForm) {
                cartForm.addEventListener('submit', function (e) {
                    e.preventDefault();

                    Swal.fire({
                        icon: 'success',
                        title: 'Added to Bag',
                        text: 'Item has been added to your shopping bag!',
                        confirmButtonText: 'Great'
                    }).then(() => {
                        this.submit();
                    });
                });
            }
        });
    </script>

    <script src="/static/js/main.js"></script>
</body>
</html>